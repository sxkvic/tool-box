/**
 * Mission Control UI
 * 灵感：SpaceX 全屏叙事 + 航天 HUD + 赛博控制台
 * 特征：深空底、青色光晕、网格、角标、入场动画、状态灯
 */

page {
  --accent: #5ce1ff;
  --accent-2: #7c9cff;
  --accent-soft: rgba(92, 225, 255, 0.12);
  --accent-glow: rgba(92, 225, 255, 0.35);
  --primary: #ffffff;
  --primary-soft: rgba(255, 255, 255, 0.08);
  --primary-deep: #e8e8e8;
  --link: #9eb6ff;
  --warning: #ffb020;
  --danger: #ff5c7a;
  --success: #3dff9a;

  --bg: #05070c;
  --bg-elevated: rgba(255, 255, 255, 0.04);
  --card: rgba(12, 16, 28, 0.88);

  --text: #f4f7ff;
  --text-secondary: #8b95ad;
  --text-muted: #5a6478;
  --text-on-primary: #05070c;

  --border: rgba(255, 255, 255, 0.08);
  --border-strong: rgba(92, 225, 255, 0.28);
  --radius-sm: 10rpx;
  --radius: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 999rpx;

  background: var(--bg);
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue',
    'Microsoft YaHei', sans-serif;
}

/* 深空氛围底：径向光 + 细网格 */
.container {
  position: relative;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background:
    radial-gradient(1200rpx 600rpx at 10% -10%, rgba(92, 225, 255, 0.12), transparent 55%),
    radial-gradient(900rpx 500rpx at 100% 0%, rgba(124, 156, 255, 0.10), transparent 50%),
    linear-gradient(180deg, #070b14 0%, #05070c 40%, #05070c 100%);
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0.22;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.03) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  mask-image: linear-gradient(180deg, #000 0%, transparent 85%);
}

.container > view,
.container > button {
  position: relative;
  z-index: 1;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}

/* HUD 卡片 */
.card {
  position: relative;
  background: linear-gradient(160deg, rgba(18, 24, 40, 0.95), rgba(10, 14, 24, 0.92));
  border-radius: var(--radius);
  padding: 28rpx 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid var(--border);
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.35);
  overflow: hidden;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(92, 225, 255, 0.55), transparent);
}

.card::after {
  content: '';
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 12rpx;
  height: 12rpx;
  border-top: 2rpx solid rgba(92, 225, 255, 0.45);
  border-right: 2rpx solid rgba(92, 225, 255, 0.45);
  opacity: 0.7;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 20rpx;
}

.card-title::before {
  content: '';
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--accent);
  box-shadow: 0 0 12rpx var(--accent-glow);
}

.section-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
  min-width: 0;
}

.input,
.textarea,
.picker-value {
  width: 100%;
  background: rgba(0, 0, 0, 0.35);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.input {
  height: 84rpx;
  padding: 0 24rpx;
}

.textarea {
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  line-height: 1.6;
}

.picker-value {
  height: 84rpx;
  line-height: 84rpx;
  padding: 0 24rpx;
}

/* ========== Buttons · Mission Control ========== */
.btn-primary {
  position: relative;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(180deg, #f7fbff 0%, #d9e8ff 48%, #c8dcff 100%) !important;
  color: #07101c !important;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: none;
  margin-top: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 0 28rpx;
  overflow: hidden;
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.35),
    0 8rpx 28rpx rgba(92, 225, 255, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.btn-primary::before {
  content: '';
  position: absolute;
  left: 8%;
  right: 8%;
  top: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.95), transparent);
  pointer-events: none;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.985) translateY(1rpx);
  opacity: 0.94;
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.28),
    0 4rpx 16rpx rgba(92, 225, 255, 0.16);
}

.btn-primary[disabled] {
  opacity: 1;
  box-shadow: none;
  color: #8b95ad !important;
  background: linear-gradient(180deg, rgba(40, 48, 68, 0.95), rgba(24, 30, 46, 0.95)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1) !important;
}

/* 次按钮：青描边幽灵 */
.btn-ghost {
  position: relative;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
  color: #e8f1ff !important;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.28);
  margin: 0;
  padding: 0 24rpx;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 4rpx 16rpx rgba(0, 0, 0, 0.18);
}

.btn-ghost::after {
  border: none;
}

.btn-ghost:active {
  background: rgba(92, 225, 255, 0.12);
  border-color: rgba(92, 225, 255, 0.55);
  color: #5ce1ff;
  box-shadow: 0 0 18rpx rgba(92, 225, 255, 0.12);
}

.btn-ghost[disabled] {
  opacity: 1;
  color: #6b758c !important;
  border-color: rgba(255, 255, 255, 0.1);
  background: rgba(18, 22, 34, 0.9) !important;
  box-shadow: none;
}

/* 激励按钮 */
.btn-reward {
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  background: linear-gradient(180deg, rgba(255, 176, 32, 0.16), rgba(255, 176, 32, 0.06));
  color: #ffb020;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(255, 176, 32, 0.45);
  margin-top: 20rpx;
  box-shadow: 0 0 22rpx rgba(255, 176, 32, 0.12);
}

.btn-reward::after {
  border: none;
}

.btn-reward:active {
  opacity: 0.9;
  background: rgba(255, 176, 32, 0.2);
}

/* 结果面板 */
.result-box {
  position: relative;
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(160deg, rgba(14, 28, 40, 0.95), rgba(10, 14, 24, 0.95));
  border-radius: var(--radius);
  border: 1rpx solid rgba(92, 225, 255, 0.22);
  box-shadow: 0 0 40rpx rgba(92, 225, 255, 0.08);
  overflow: hidden;
  animation: resultIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.result-box::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 30%, rgba(92, 225, 255, 0.08) 50%, transparent 70%);
  transform: translateX(-120%);
  animation: shimmer 2.4s ease-in-out infinite;
  pointer-events: none;
}

.result-label {
  font-size: 20rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 12rpx;
}

.result-value {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text);
  word-break: break-all;
  line-height: 1.25;
  letter-spacing: 1rpx;
  text-shadow: 0 0 24rpx rgba(92, 225, 255, 0.25);
}

.result-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 标签选择 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  min-width: 120rpx;
  padding: 14rpx 26rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #8b95ad;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  letter-spacing: 1rpx;
  box-sizing: border-box;
}

.tag:active {
  opacity: 0.9;
}

.tag.active {
  background: linear-gradient(180deg, rgba(92, 225, 255, 0.2), rgba(92, 225, 255, 0.08));
  color: #5ce1ff;
  border-color: rgba(92, 225, 255, 0.55);
  box-shadow:
    0 0 18rpx rgba(92, 225, 255, 0.16),
    inset 0 0 12rpx rgba(92, 225, 255, 0.08);
  font-weight: 700;
}

.ad-slot {
  margin: 16rpx 0 8rpx;
  min-height: 0;
  border-radius: var(--radius);
  overflow: hidden;
}

/* 并排按钮组 */
.row-btns {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  align-items: stretch;
}

.flex-btn {
  flex: 1;
  margin: 0 !important;
  padding: 0 12rpx !important;
  min-width: 0;
  box-sizing: border-box;
}

/* 并排中主按钮与 ghost 同高 */
.flex-btn.calc,
.row-btns .btn-primary.flex-btn,
.row-btns .btn-primary {
  height: 76rpx !important;
  line-height: 76rpx !important;
  border-radius: 12rpx !important;
  margin-top: 0 !important;
  font-size: 26rpx !important;
  letter-spacing: 2rpx !important;
  padding: 0 12rpx !important;
}

.row-btns .btn-ghost.flex-btn,
.row-btns .btn-ghost {
  height: 76rpx !important;
  line-height: 76rpx !important;
  font-size: 24rpx !important;
}


/* 结果区 / 卡片内嵌按钮统一 */
.result-box .btn-ghost,
.card .btn-ghost {
  box-sizing: border-box;
}

.result-box > .btn-ghost,
.result-box > .btn-primary {
  width: 100%;
}

/* 主 CTA 在卡片底部更贴合控制台 */
.card > .btn-primary:last-child {
  margin-bottom: 0;
}

/* 默认 button 去边框残留 */
button {
  position: relative;
}

button::after {
  border: none !important;
}

/* 通用动画 */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes resultIn {
  from {
    opacity: 0;
    transform: translateY(16rpx) scale(0.98);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes shimmer {
  0%, 100% { transform: translateX(-120%); }
  50% { transform: translateX(120%); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(92, 225, 255, 0.55); }
  50% { opacity: 0.75; box-shadow: 0 0 0 10rpx rgba(92, 225, 255, 0); }
}

@keyframes scan {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(220%); }
}

@keyframes floatGlow {
  0%, 100% { opacity: 0.55; transform: scale(1); }
  50% { opacity: 0.9; transform: scale(1.05); }
}

.anim-fade-up {
  animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.anim-delay-1 { animation-delay: 0.06s; }
.anim-delay-2 { animation-delay: 0.12s; }
.anim-delay-3 { animation-delay: 0.18s; }
.anim-delay-4 { animation-delay: 0.24s; }



/* ========== Tool action layout (non-weight shared) ========== */
.card-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  align-items: stretch;
}

.card-actions .btn-primary,
.card-actions .btn-ghost {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  margin: 0 !important;
  height: 84rpx !important;
  line-height: 84rpx !important;
  font-size: 28rpx !important;
  letter-spacing: 1rpx !important;
  border-radius: 14rpx !important;
  padding: 0 12rpx !important;
  box-sizing: border-box;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  overflow: visible !important;
}

.card-actions.single .btn-primary {
  height: 92rpx !important;
  line-height: 92rpx !important;
  font-size: 30rpx !important;
}

.card-actions.single .btn-primary,
.card-actions.single .btn-ghost {
  flex: 1 1 auto;
  width: 100%;
}

.result-actions {
  margin-top: 20rpx;
}

.result-actions .btn-primary,
.result-actions .btn-ghost {
  width: 100%;
  margin: 0 !important;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 18rpx;
}

.action-stack .btn-primary,
.action-stack .btn-ghost {
  width: 100%;
  margin: 0 !important;
}

.btn-block {
  width: 100% !important;
  margin-top: 0 !important;
}

.btn-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  align-items: stretch;
}

.btn-row .btn-primary,
.btn-row .btn-ghost,
.btn-row .flex-1 {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  margin: 0 !important;
  height: 84rpx !important;
  line-height: 84rpx !important;
  font-size: 28rpx !important;
  border-radius: 14rpx !important;
  box-sizing: border-box;
}

.tool-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 92rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 720;
  letter-spacing: 1rpx;
  box-sizing: border-box;
}

.tool-cta.primary {
  color: #07101c;
  background: linear-gradient(180deg, #f7fbff 0%, #d9e8ff 48%, #c8dcff 100%);
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.28),
    0 10rpx 28rpx rgba(92, 225, 255, 0.18);
}

.tool-cta.primary:active {
  transform: scale(0.985);
  opacity: 0.94;
}

.theme-light .tool-cta.primary {
  color: #ffffff;
  background: linear-gradient(180deg, #3b82f6 0%, #2563eb 52%, #1d4ed8 100%);
  box-shadow: 0 10rpx 24rpx rgba(37, 99, 235, 0.28);
}

.theme-light .tool-cta.primary[disabled],
.tool-cta.primary[disabled] {
  opacity: 0.55;
}

/* =========================================================
 * Clean Lab · 纯白极简（独立视觉体系）
 * 不是深空换色：去掉 HUD 角标/赛博描边/霓虹光，改用纸感卡片与柔和阴影
 * ========================================================= */
page.theme-light,
.theme-light {
  --accent: #2563eb;
  --accent-2: #3b82f6;
  --accent-soft: rgba(37, 99, 235, 0.08);
  --accent-glow: rgba(37, 99, 235, 0.14);
  --primary: #2563eb;
  --primary-soft: rgba(37, 99, 235, 0.08);
  --primary-deep: #1d4ed8;
  --link: #2563eb;
  --warning: #d97706;
  --danger: #e11d48;
  --success: #16a34a;

  --bg: #eef2f7;
  --bg-elevated: #ffffff;
  --card: #ffffff;

  --text: #0f172a;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --text-on-primary: #ffffff;

  --border: rgba(15, 23, 42, 0.06);
  --border-strong: rgba(37, 99, 235, 0.22);

  background: var(--bg);
  color: var(--text);
}

/* 工具页浅底：柔和天蓝雾，无网格赛博感 */
.theme-light.container,
.container.theme-light,
page.theme-light .container {
  background:
    radial-gradient(900rpx 420rpx at 12% -10%, rgba(59, 130, 246, 0.1), transparent 58%),
    radial-gradient(700rpx 360rpx at 100% 0%, rgba(14, 165, 233, 0.06), transparent 52%),
    linear-gradient(180deg, #f5f7fb 0%, #eef2f7 45%, #e9eef5 100%);
}

.theme-light.container::before,
.container.theme-light::before,
page.theme-light .container::before {
  display: none;
}

/* 白卡片：纸感 + 轻阴影，去掉顶部霓虹线与角标 */
.theme-light .card,
page.theme-light .card {
  background: #ffffff;
  border: none;
  border-radius: 22rpx;
  box-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.9) inset,
    0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.theme-light .card::before,
page.theme-light .card::before,
.theme-light .card::after,
page.theme-light .card::after {
  display: none;
}

.theme-light .card-title,
page.theme-light .card-title {
  color: #334155;
  letter-spacing: 1rpx;
  text-transform: none;
  font-size: 26rpx;
  font-weight: 700;
}

.theme-light .card-title::before,
page.theme-light .card-title::before {
  width: 8rpx;
  height: 8rpx;
  background: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.12);
}

.theme-light .section-tip,
page.theme-light .section-tip {
  color: #64748b;
}

/* 输入：浅灰底，圆润，无深色 inset */
.theme-light .input,
.theme-light .textarea,
.theme-light .picker-value,
page.theme-light .input,
page.theme-light .textarea,
page.theme-light .picker-value {
  background: #f1f5f9;
  color: #0f172a;
  border: 1rpx solid transparent;
  border-radius: 14rpx;
  box-shadow: none;
}

/* 主按钮：实心蓝，不是浅金属白片 */
.theme-light .btn-primary,
page.theme-light .btn-primary {
  background: linear-gradient(180deg, #3b82f6 0%, #2563eb 52%, #1d4ed8 100%) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: 16rpx !important;
  letter-spacing: 2rpx;
  box-shadow:
    0 10rpx 24rpx rgba(37, 99, 235, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.28) !important;
}

.theme-light .btn-primary::before,
page.theme-light .btn-primary::before {
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.55), transparent);
}

.theme-light .btn-primary:active,
page.theme-light .btn-primary:active {
  opacity: 0.94;
  box-shadow: 0 4rpx 14rpx rgba(37, 99, 235, 0.2) !important;
}

.theme-light .btn-primary[disabled],
page.theme-light .btn-primary[disabled] {
  color: #94a3b8 !important;
  background: #e2e8f0 !important;
  box-shadow: none !important;
  border: none !important;
}

/* 次按钮：白底灰边，不是青描边幽灵 */
.theme-light .btn-ghost,
page.theme-light .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
  border-radius: 14rpx !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04) !important;
  letter-spacing: 1rpx;
}

.theme-light .btn-ghost:active,
page.theme-light .btn-ghost:active {
  background: #eff6ff !important;
  border-color: #bfdbfe !important;
  color: #2563eb !important;
  box-shadow: none !important;
}

.theme-light .btn-ghost[disabled],
page.theme-light .btn-ghost[disabled] {
  color: #94a3b8 !important;
  background: #f8fafc !important;
  border-color: #e2e8f0 !important;
  box-shadow: none !important;
  opacity: 1 !important;
}

.theme-light .btn-reward,
page.theme-light .btn-reward {
  background: #fff7ed;
  color: #c2410c;
  border: 1rpx solid #fed7aa;
  box-shadow: none;
}

/* 结果区：淡蓝信息卡 */
.theme-light .result-box,
page.theme-light .result-box {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.08);
}

.theme-light .result-box::before,
page.theme-light .result-box::before {
  display: none;
}

.theme-light .result-label,
page.theme-light .result-label {
  color: #2563eb;
  text-transform: none;
  letter-spacing: 1rpx;
}

.theme-light .result-value,
page.theme-light .result-value {
  color: #0f172a;
  text-shadow: none;
}

.theme-light .result-sub,
page.theme-light .result-sub {
  color: #64748b;
}

/* 标签：胶囊浅灰 / 选中淡蓝 */
.theme-light .tag,
page.theme-light .tag {
  background: #f1f5f9;
  color: #64748b;
  border: none;
  box-shadow: none;
}

.theme-light .tag.active,
page.theme-light .tag.active {
  background: #dbeafe;
  color: #1d4ed8;
  border: none;
  box-shadow: none;
  font-weight: 700;
}

/* 并排按钮高度继承全局，颜色走上面覆盖即可 */
.theme-light .row-btns .btn-primary,
.theme-light .flex-btn.calc,
page.theme-light .row-btns .btn-primary,
page.theme-light .flex-btn.calc {
  color: #ffffff !important;
  background: linear-gradient(180deg, #3b82f6 0%, #2563eb 55%, #1d4ed8 100%) !important;
}
.btn-primary-hover {
  opacity: 0.92;
  transform: scale(0.985);
}

.btn-ghost-hover {
  opacity: 0.92;
  transform: scale(0.985);
}
