.quota {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 18rpx 18rpx 18rpx 16rpx;
  background: linear-gradient(135deg, rgba(14, 22, 38, 0.96), rgba(8, 12, 22, 0.96));
  border-radius: 16rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.18);
  box-shadow:
    0 10rpx 28rpx rgba(0, 0, 0, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
  overflow: hidden;
}

.quota::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(92, 225, 255, 0.5), transparent);
}

.quota-left {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.quota-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: rgba(92, 225, 255, 0.08);
  border: 1rpx solid rgba(92, 225, 255, 0.2);
  color: #5ce1ff;
  font-size: 14rpx;
  letter-spacing: 1rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.quota-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #5ce1ff;
  box-shadow: 0 0 10rpx rgba(92, 225, 255, 0.7);
  animation: pulse 1.8s ease-in-out infinite;
}

.quota-texts {
  min-width: 0;
}

.quota-title {
  font-size: 26rpx;
  color: #f4f7ff;
  font-weight: 500;
}

.quota-num {
  color: #5ce1ff;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.quota-sub {
  margin-top: 4rpx;
  font-size: 20rpx;
  color: #5a6478;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  letter-spacing: 1rpx;
}

/* Mission Control 激励动作按钮 */
.quota-btn {
  position: relative;
  margin: 0;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  min-width: 156rpx;
  background: linear-gradient(180deg, rgba(92, 225, 255, 0.22), rgba(92, 225, 255, 0.08));
  color: #e8fbff;
  font-size: 22rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.45);
  flex-shrink: 0;
  letter-spacing: 1rpx;
  font-weight: 700;
  overflow: hidden;
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.08),
    0 6rpx 18rpx rgba(92, 225, 255, 0.14),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.18);
}

.quota-btn::before {
  content: '';
  position: absolute;
  left: 12%;
  right: 12%;
  top: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.75), transparent);
  pointer-events: none;
}

.quota-btn::after {
  border: none;
}

.quota-btn:active {
  transform: scale(0.97);
  background: linear-gradient(180deg, rgba(92, 225, 255, 0.3), rgba(92, 225, 255, 0.14));
  box-shadow:
    0 0 20rpx rgba(92, 225, 255, 0.22),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.22);
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.65; transform: scale(0.9); }
}

/* Clean Lab 配额条 */
.quota-light {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.quota-light::before {
  display: none;
}

.quota-light .quota-badge {
  background: #eff6ff;
  border: none;
  color: #2563eb;
  border-radius: 16rpx;
}

.quota-light .quota-dot {
  background: #2563eb;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.12);
  animation: none;
}

.quota-light .quota-title {
  color: #0f172a;
}

.quota-light .quota-num {
  color: #2563eb;
}

.quota-light .quota-sub {
  color: #94a3b8;
}

.quota-light .quota-btn {
  background: #eff6ff;
  color: #1d4ed8;
  border: none;
  border-radius: 14rpx;
  box-shadow: none;
  font-weight: 700;
}

.quota-light .quota-btn::before {
  display: none;
}

.quota-light .quota-btn:active {
  background: #dbeafe;
  transform: scale(0.97);
  box-shadow: none;
}
.quota-free-tag {
  min-width: 64rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #3dff9a;
  background: rgba(61, 255, 154, 0.1);
  border: 1rpx solid rgba(61, 255, 154, 0.35);
}

.quota-free .quota-badge {
  border-color: rgba(61, 255, 154, 0.35);
  color: #3dff9a;
  background: rgba(61, 255, 154, 0.08);
}

.quota-light.quota-free .quota-free-tag {
  color: #059669;
  background: #ecfdf5;
  border-color: #6ee7b7;
}