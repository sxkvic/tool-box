/* Mission Control Homepage */
.page {
  position: relative;
  min-height: 100vh;
  padding: 8rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #05070c;
  overflow: hidden;
}

.bg-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(2rpx);
  animation: floatGlow 6s ease-in-out infinite;
}

.orb-a {
  width: 420rpx;
  height: 420rpx;
  top: -120rpx;
  left: -80rpx;
  background: radial-gradient(circle, rgba(92, 225, 255, 0.28), transparent 68%);
}

.orb-b {
  width: 360rpx;
  height: 360rpx;
  top: 80rpx;
  right: -100rpx;
  background: radial-gradient(circle, rgba(124, 156, 255, 0.22), transparent 70%);
  animation-delay: 1.2s;
}

.grid-mask {
  position: absolute;
  inset: 0;
  opacity: 0.28;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.035) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1rpx, transparent 1rpx);
  background-size: 48rpx 48rpx;
  mask-image: linear-gradient(180deg, #000 0%, transparent 72%);
}

.scanline {
  position: absolute;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(180deg, transparent, rgba(92, 225, 255, 0.08), transparent);
  animation: scan 4.8s linear infinite;
  opacity: 0.7;
}

.hero,
.search-wrap,
.section-head,
.tool-grid,
.empty,
.ad-slot,
.footer {
  position: relative;
  z-index: 1;
}

/* Hero */
.hero {
  margin-top: 12rpx;
  padding: 28rpx 24rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, rgba(16, 24, 42, 0.92), rgba(8, 12, 22, 0.88));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.35);
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, transparent 20%, rgba(92, 225, 255, 0.08) 45%, transparent 70%);
  animation: shimmer 3.2s ease-in-out infinite;
  pointer-events: none;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.hero-top .theme-switch {
  margin-left: 16rpx;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(61, 255, 154, 0.08);
  border: 1rpx solid rgba(61, 255, 154, 0.28);
  color: #3dff9a;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  font-weight: 600;
  max-width: calc(100% - 180rpx);
  overflow: hidden;
  box-sizing: border-box;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #3dff9a;
  animation: pulse 1.8s ease-in-out infinite;
}

.hero-code {
  font-size: 18rpx;
  color: #5a6478;
  letter-spacing: 3rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #f4f7ff;
  letter-spacing: 2rpx;
  line-height: 1.15;
  text-shadow: 0 0 30rpx rgba(92, 225, 255, 0.2);
}

.hero-sub {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #8b95ad;
  letter-spacing: 2rpx;
}

.hero-meta {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.meta-num {
  font-size: 28rpx;
  font-weight: 700;
  color: #5ce1ff;
  letter-spacing: 1rpx;
}

.meta-label {
  font-size: 16rpx;
  color: #5a6478;
  letter-spacing: 2rpx;
}

.meta-divider {
  width: 1rpx;
  height: 40rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* Search */
.search-wrap {
  margin-top: 22rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 22rpx;
  gap: 12rpx;
  background: rgba(10, 14, 24, 0.9);
  border-radius: 14rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.18);
  box-shadow: 0 0 24rpx rgba(92, 225, 255, 0.06);
}



.search-input {
  margin-left: 8rpx;
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
  color: #f4f7ff;
}

.search-ph {
  color: #5a6478;
}

.search-clear {
  font-size: 22rpx;
  color: #9eb6ff;
  margin-left: 12rpx;
  flex-shrink: 0;
  padding: 8rpx 0;
  letter-spacing: 1rpx;
}

/* Section */
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 4rpx 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #f4f7ff;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.section-mark {
  color: #5ce1ff;
}

.section-count {
  min-width: 40rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(92, 225, 255, 0.12);
  color: #5ce1ff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 36rpx;
  text-align: center;
  border: 1rpx solid rgba(92, 225, 255, 0.25);
}

/* Tool cards grid */
.tool-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 0;
}

.tool-card {
  position: relative;
  width: calc(50% - 8rpx);
  padding: 22rpx 20rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(160deg, rgba(16, 22, 38, 0.96), rgba(8, 12, 22, 0.96));
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.28);
}

.tool-card-glow {
  position: absolute;
  top: -40rpx;
  right: -30rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(92, 225, 255, 0.16), transparent 70%);
  pointer-events: none;
}

.tool-card-corner {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid rgba(92, 225, 255, 0.5);
  border-right: 2rpx solid rgba(92, 225, 255, 0.5);
}

.tool-card-hover {
  transform: translateY(-4rpx) scale(0.99);
  border-color: rgba(92, 225, 255, 0.35);
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.12),
    0 16rpx 36rpx rgba(92, 225, 255, 0.12);
}

.tool-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.tool-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(92, 225, 255, 0.08);
  border: 1rpx solid rgba(92, 225, 255, 0.22);
  box-shadow: inset 0 0 18rpx rgba(92, 225, 255, 0.08);
  padding: 0;
}



.tool-id {
  font-size: 16rpx;
  color: #5a6478;
  letter-spacing: 1rpx;
}

.tool-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #f4f7ff;
  line-height: 1.3;
  letter-spacing: 1rpx;
}

.tool-desc {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #8b95ad;
  line-height: 1.4;
  min-height: 56rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.tool-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.tool-action {
  font-size: 18rpx;
  color: #5ce1ff;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.tool-arrow {
  font-size: 28rpx;
  color: rgba(92, 225, 255, 0.7);
  line-height: 1;
}

.empty {
  margin: 100rpx 24rpx;
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #f4f7ff;
  letter-spacing: 4rpx;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8b95ad;
}

.footer {
  margin-top: 40rpx;
  padding: 0 8rpx 8rpx;
  text-align: center;
}

.footer-line {
  height: 1rpx;
  margin: 0 auto 18rpx;
  width: 120rpx;
  background: linear-gradient(90deg, transparent, rgba(92, 225, 255, 0.45), transparent);
}

.footer-tip {
  font-size: 18rpx;
  color: #5a6478;
  letter-spacing: 2rpx;
}

.ad-slot {
  margin: 28rpx 0 0;
}

.anim-fade-up {
  animation: fadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.anim-delay-1 { animation-delay: 0.06s; }
.anim-delay-2 { animation-delay: 0.12s; }

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(61, 255, 154, 0.55); }
  50% { opacity: 0.7; box-shadow: 0 0 0 10rpx rgba(61, 255, 154, 0); }
}

@keyframes scan {
  0% { transform: translateY(-20%); }
  100% { transform: translateY(180%); }
}

@keyframes shimmer {
  0%, 100% { transform: translateX(-120%); }
  55% { transform: translateX(120%); }
}

@keyframes floatGlow {
  0%, 100% { opacity: 0.55; transform: scale(1); }
  50% { opacity: 0.95; transform: scale(1.08); }
}

/* =========================================================
 * Homepage light theme
 * ========================================================= */

/* =========================================================
 * Clean Lab · 白色系独立视觉（不是深空皮肤换色）
 * 特征：纸感浅底、柔和阴影、圆润卡片、低饱和蓝、无 HUD 角标感
 * ========================================================= */
.page.theme-light {
  background: #eef2f7;
}

.page.theme-light .bg-layer {
  opacity: 1;
}

.page.theme-light .orb-a {
  width: 520rpx;
  height: 520rpx;
  top: -180rpx;
  left: -120rpx;
  background: radial-gradient(circle, rgba(59, 130, 246, 0.14), transparent 70%);
  filter: blur(4rpx);
  animation: none;
  opacity: 1;
}

.page.theme-light .orb-b {
  width: 420rpx;
  height: 420rpx;
  top: 120rpx;
  right: -140rpx;
  background: radial-gradient(circle, rgba(14, 165, 233, 0.1), transparent 72%);
  filter: blur(4rpx);
  animation: none;
  opacity: 1;
}

/* 白色系关掉网格与扫描线，避免赛博感 */
.page.theme-light .grid-mask,
.page.theme-light .scanline {
  display: none;
}

.page.theme-light .hero {
  margin-top: 8rpx;
  padding: 30rpx 26rpx 26rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: none;
  box-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.9) inset,
    0 12rpx 40rpx rgba(15, 23, 42, 0.07);
  overflow: hidden;
}

.page.theme-light .hero::before {
  display: none;
}

.page.theme-light .status-chip {
  background: #eff6ff;
  border: none;
  color: #2563eb;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.page.theme-light .status-dot {
  background: #22c55e;
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.15);
  animation: none;
}

.page.theme-light .hero-code {
  color: #94a3b8;
}

.page.theme-light .hero-title {
  color: #0f172a;
  font-weight: 750;
  letter-spacing: 1rpx;
  text-shadow: none;
}

.page.theme-light .hero-sub {
  color: #64748b;
  letter-spacing: 1rpx;
}

.page.theme-light .hero-meta {
  margin-top: 22rpx;
  background: #f8fafc;
  border: none;
  border-top: none;
  border-radius: 18rpx;
  padding: 16rpx 8rpx;
}

.page.theme-light .meta-num {
  color: #0f172a;
  text-shadow: none;
}

.page.theme-light .meta-label {
  color: #94a3b8;
}

.page.theme-light .meta-divider {
  background: #e2e8f0;
  opacity: 1;
}

/* 固定尺寸胶囊：字数变化也不抖 */
.theme-switch {
  position: relative;
  width: 148rpx;
  height: 56rpx;
  padding: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
  overflow: hidden;
  flex-shrink: 0;
  background: rgba(92, 225, 255, 0.1);
  border: 1rpx solid rgba(92, 225, 255, 0.28);
  color: #5ce1ff;
  transition: transform 0.2s ease, opacity 0.2s ease, background 0.35s ease, border-color 0.35s ease;
}

.theme-switch-track {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 12rpx 0 8rpx;
  box-sizing: border-box;
  gap: 8rpx;
}

.theme-switch-thumb {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(92, 225, 255, 0.16);
  border: 1rpx solid rgba(92, 225, 255, 0.28);
}

.theme-switch-label {
  width: 72rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: clip;
  white-space: nowrap;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1;
  color: inherit;
}

.theme-switch-ico {
  display: inline-block;
  font-size: 22rpx;
  line-height: 1;
  transform-origin: 50% 50%;
}

.theme-switch::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(110deg, transparent 30%, rgba(255, 255, 255, 0.28) 48%, transparent 66%);
  transform: translateX(-120%);
  pointer-events: none;
}

.theme-switch.spinning {
  transform: scale(0.97);
}

.theme-switch.spinning::after {
  animation: switchShine 0.48s ease-out;
}

.theme-switch.spinning .theme-switch-ico {
  animation: switchFlip 0.48s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-switch-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 白色系开关：浅轨 + 蓝滑块 */
.page.theme-light .theme-switch,
.theme-switch-light {
  background: #e8eef8;
  border: 1rpx solid #d7e3f4;
  color: #1d4ed8;
  box-shadow: inset 0 1rpx 2rpx rgba(15, 23, 42, 0.04);
}

.page.theme-light .theme-switch-thumb,
.theme-switch-light .theme-switch-thumb {
  background: #ffffff;
  border: 1rpx solid #cfe0f7;
  box-shadow: 0 4rpx 10rpx rgba(37, 99, 235, 0.12);
  color: #2563eb;
}

/* 搜索 */
.page.theme-light .search-box {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.page.theme-light .search-input {
  color: #0f172a;
}

.page.theme-light .search-ph {
  color: #94a3b8;
}

.page.theme-light .search-clear {
  color: #2563eb;
  background: #eff6ff;
  border-radius: 999rpx;
}

/* 分区标题 */
.page.theme-light .section-title {
  color: #0f172a;
  font-weight: 700;
}

.page.theme-light .section-mark {
  color: #2563eb;
}

.page.theme-light .section-count {
  color: #64748b;
  background: #e8eef8;
  border: none;
}

/* 工具卡片：白纸卡片，不是 HUD */
.page.theme-light .tool-card {
  background: #ffffff;
  border: none;
  border-radius: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.05);
}

.page.theme-light .tool-card-glow {
  background: radial-gradient(circle, rgba(37, 99, 235, 0.08), transparent 70%);
}

.page.theme-light .tool-card-corner {
  display: none;
}

.page.theme-light .tool-card-hover {
  transform: translateY(-4rpx);
  border: none;
  box-shadow:
    0 16rpx 36rpx rgba(37, 99, 235, 0.12),
    0 2rpx 0 rgba(255, 255, 255, 0.8) inset;
}

.page.theme-light .tool-icon-wrap {
  background: #eff6ff;
  border: none;
  border-radius: 18rpx;
  box-shadow: none;
}

.page.theme-light .tool-id {
  color: #94a3b8;
  letter-spacing: 1rpx;
}

.page.theme-light .tool-name {
  color: #0f172a;
}

.page.theme-light .tool-desc {
  color: #64748b;
}

.page.theme-light .tool-foot {
  border-top: 1rpx solid #eef2f7;
}

.page.theme-light .tool-action {
  color: #2563eb;
  letter-spacing: 1rpx;
}

.page.theme-light .tool-arrow {
  color: #60a5fa;
}

.page.theme-light .empty-title {
  color: #0f172a;
}

.page.theme-light .empty-desc,
.page.theme-light .footer-tip {
  color: #94a3b8;
}

.page.theme-light .footer-line {
  background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.28), transparent);
}

/* 切换遮罩 */
.theme-veil {
  position: fixed;
  inset: 0;
  z-index: 50;
  pointer-events: none;
  opacity: 0;
  transform: scale(1.02);
  transition: opacity 0.22s ease, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
}

.theme-veil.show {
  opacity: 1;
  transform: scale(1);
}

.theme-veil.veil-to-light {
  background:
    radial-gradient(circle at 86% 8%, rgba(255, 255, 255, 0.95), transparent 36%),
    linear-gradient(160deg, rgba(238, 242, 247, 0.82), rgba(255, 255, 255, 0.55));
}

.theme-veil.veil-to-mc {
  background:
    radial-gradient(circle at 86% 8%, rgba(92, 225, 255, 0.28), transparent 36%),
    linear-gradient(160deg, rgba(5, 7, 12, 0.72), rgba(8, 12, 22, 0.5));
}

.page.theme-animating .hero,
.page.theme-animating .search-wrap,
.page.theme-animating .section-head,
.page.theme-animating .tool-grid,
.page.theme-animating .empty,
.page.theme-animating .footer {
  animation: themeContentPulse 0.48s cubic-bezier(0.22, 1, 0.36, 1);
}

.page .hero,
.page .search-box,
.page .tool-card,
.page .status-chip,
.page .section-count,
.page .theme-switch {
  transition:
    background 0.35s ease,
    border-color 0.35s ease,
    color 0.35s ease,
    box-shadow 0.35s ease;
}

.page .hero-title,
.page .hero-sub,
.page .tool-name,
.page .tool-desc,
.page .meta-num,
.page .meta-label,
.page .tool-action,
.page .footer-tip {
  transition: color 0.35s ease;
}

@keyframes switchFlip {
  0% { transform: rotate(-12deg) scale(0.85); opacity: 0.55; }
  45% { transform: rotate(160deg) scale(1.12); opacity: 1; }
  100% { transform: rotate(360deg) scale(1); opacity: 1; }
}

@keyframes switchShine {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(120%); }
}

@keyframes themeContentPulse {
  0% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
  35% { opacity: 0.88; transform: translateY(4rpx) scale(0.992); filter: blur(1rpx); }
  100% { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
}
/* Category sections */
.section-en {
  margin-left: 12rpx;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  color: var(--text-muted, #5a6478);
  font-weight: 500;
}

.section-desc {
  position: relative;
  z-index: 1;
  margin: -6rpx 4rpx 16rpx;
  font-size: 22rpx;
  color: #5a6478;
  letter-spacing: 1rpx;
}

.page.theme-light .section-en {
  color: #94a3b8;
}

.page.theme-light .section-desc {
  color: #94a3b8;
}

.page.theme-animating .section-desc {
  animation: themeContentPulse 0.48s cubic-bezier(0.22, 1, 0.36, 1);
}

/* Quick chips: recent / favorites */
.quick-row {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 0 0 8rpx;
}

.quick-chip {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  max-width: 100%;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-sizing: border-box;
}

.quick-chip-hover {
  border-color: rgba(92, 225, 255, 0.4);
  background: rgba(92, 225, 255, 0.08);
}

.quick-name {
  font-size: 24rpx;
  color: #e8eefc;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-head-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.section-link {
  font-size: 22rpx;
  color: var(--text-muted, #5a6478);
  padding: 6rpx 4rpx;
  letter-spacing: 1rpx;
}

.section-link:active {
  color: #ff5c7a;
}

.recent-del {
  margin-left: 2rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 28rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 500;
  color: #5a6478;
  border-radius: 50%;
  flex-shrink: 0;
}

.recent-del-hover {
  color: #ff5c7a;
  background: rgba(255, 92, 122, 0.12);
}

.page.theme-light .section-link {
  color: #94a3b8;
}

.page.theme-light .section-link:active {
  color: #e11d48;
}

.page.theme-light .recent-del {
  color: #94a3b8;
}

.page.theme-light .recent-del-hover {
  color: #e11d48;
  background: rgba(225, 29, 72, 0.08);
}

.fav-btn {
  margin-left: 4rpx;
  font-size: 22rpx;
  color: #5a6478;
  padding: 0 4rpx;
}

.fav-btn.on {
  color: #ffb020;
}

.fav-mark {
  position: absolute;
  top: 12rpx;
  right: 28rpx;
  z-index: 3;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #5a6478;
}

.fav-mark.on {
  color: #ffb020;
  text-shadow: 0 0 12rpx rgba(255, 176, 32, 0.45);
}

.page.theme-light .quick-chip {
  background: #ffffff;
  border-color: #e2e8f0;
  box-shadow: 0 4rpx 14rpx rgba(15, 23, 42, 0.04);
}

.page.theme-light .quick-chip-hover {
  border-color: #93c5fd;
  background: #eff6ff;
}

.page.theme-light .quick-name {
  color: #0f172a;
}

.page.theme-light .fav-btn {
  color: #94a3b8;
}

.page.theme-light .fav-btn.on,
.page.theme-light .fav-mark.on {
  color: #f59e0b;
  text-shadow: none;
}

.page.theme-light .fav-mark {
  color: #cbd5e1;
}