.bmi-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  flex-wrap: wrap;
}

.level-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid currentColor;
  background: rgba(0, 0, 0, 0.2);
  letter-spacing: 1rpx;
}

.hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #8b95ad;
  line-height: 1.6;
  padding: 16rpx 18rpx;
  background: rgba(0, 0, 0, 0.28);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.range-list {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
}

.range-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #8b95ad;
  margin-bottom: 12rpx;
}

.range-item:last-child {
  margin-bottom: 0;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 0 10rpx currentColor;
}

/* Clean Lab */
.theme-light .hint {
  background: #f8fafc;
  border: none;
  color: #64748b;
}
.theme-light .range-list {
  border-top-color: #eef2f7;
}
.theme-light .range-item { color: #64748b; }
.theme-light .level-pill {
  background: #eff6ff;
}