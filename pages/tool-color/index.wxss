.preview-card {
  display: flex;
  gap: 24rpx;
  background: linear-gradient(160deg, rgba(16, 24, 42, 0.95), rgba(8, 12, 22, 0.95));
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.2);
  box-shadow: 0 0 30rpx rgba(92, 225, 255, 0.08);
  animation: resultIn 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.swatch {
  width: 120rpx;
  height: 120rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 0 24rpx rgba(0, 0, 0, 0.35);
}

.preview-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.pv-line {
  font-size: 28rpx;
  font-weight: 600;
  color: #f4f7ff;
  margin-top: 8rpx;
  word-break: break-all;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 16rpx rgba(92, 225, 255, 0.2);
}

.palette {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.p-item {
  width: 72rpx;
  height: 72rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.25);
}

.p-item:active {
  transform: scale(0.94);
  opacity: 0.9;
}

/* 卡片内全宽转换按钮 */
.card .btn-ghost {
  position: relative;
  height: 80rpx !important;
  line-height: 80rpx !important;
  border-radius: 12rpx !important;
  letter-spacing: 2rpx !important;
  font-weight: 600 !important;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)) !important;
  border: 1rpx solid rgba(92, 225, 255, 0.28) !important;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 4rpx 16rpx rgba(0, 0, 0, 0.16) !important;
}

.card .btn-ghost:active {
  background: rgba(92, 225, 255, 0.12) !important;
  border-color: rgba(92, 225, 255, 0.55) !important;
  color: #5ce1ff !important;
  box-shadow: 0 0 18rpx rgba(92, 225, 255, 0.14) !important;
}

@keyframes resultIn {
  from { opacity: 0; transform: translateY(12rpx) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* Clean Lab */
.theme-light .preview-card {
  background: #ffffff;
  border: none;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.06);
}
.theme-light .pv-line {
  color: #0f172a;
  text-shadow: none;
}
.theme-light .card .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04) !important;
}
.theme-light .card .btn-ghost:active {
  background: #eff6ff !important;
  color: #2563eb !important;
  border-color: #bfdbfe !important;
}
.theme-light .p-item {
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}