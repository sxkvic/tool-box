<view class="container theme-{{theme}}">
  <quota-bar id="quotaBar" free="{{true}}" />

  <view class="card">
    <view class="card-title">计算模式</view>
    <view class="tag-row">
      <view
        class="tag {{mode === item.key ? 'active' : ''}}"
        wx:for="{{modes}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onMode"
      >{{item.name}}</view>
    </view>
  </view>

  <block wx:if="{{mode === 'discount'}}">
    <view class="card">
      <view class="card-title">原价（元）</view>
      <input class="input" type="digit" placeholder="例如 199" value="{{price}}" data-key="price" bindinput="onField" />
      <view class="card-title" style="margin-top: 22rpx;">折扣（如 8.5 折）</view>
      <input class="input" type="digit" placeholder="8.5 或 0.85" value="{{rate}}" data-key="rate" bindinput="onField" />
      <view class="card-actions single">
        <button class="btn-primary" bindtap="onCalc">开始计算</button>
      </view>
    </view>
  </block>

  <block wx:elif="{{mode === 'off'}}">
    <view class="card">
      <view class="card-title">订单金额（元）</view>
      <input class="input" type="digit" placeholder="例如 268" value="{{price}}" data-key="price" bindinput="onField" />
      <view class="card-title" style="margin-top: 22rpx;">每满（元）</view>
      <input class="input" type="digit" placeholder="100" value="{{full}}" data-key="full" bindinput="onField" />
      <view class="card-title" style="margin-top: 22rpx;">减免（元）</view>
      <input class="input" type="digit" placeholder="20" value="{{minus}}" data-key="minus" bindinput="onField" />
      <view class="card-actions single">
        <button class="btn-primary" bindtap="onCalc">开始计算</button>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="card-title">基数</view>
      <input class="input" type="digit" placeholder="例如 200" value="{{base}}" data-key="base" bindinput="onField" />
      <view class="card-title" style="margin-top: 22rpx;">百分比（%）</view>
      <input class="input" type="digit" placeholder="例如 10" value="{{percent}}" data-key="percent" bindinput="onField" />
      <view class="card-actions single">
        <button class="btn-primary" bindtap="onCalc">开始计算</button>
      </view>
    </view>
  </block>

  <view class="result-box" wx:if="{{result}}">
    <view class="result-label">计算结果</view>
    <view class="result-value">{{result.main}}</view>
    <view class="lines">
      <view class="line" wx:for="{{result.lines}}" wx:key="label">
        <text class="k">{{item.label}}</text>
        <text class="v">{{item.value}}</text>
      </view>
    </view>
    <view class="result-actions">
      <button class="btn-ghost" bindtap="onCopy">复制结果</button>
    </view>
  </view>

  <view class="ad-slot"><ad-banner /></view>
</view>
