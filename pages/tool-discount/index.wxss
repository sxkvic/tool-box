.lines {
  margin-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding-top: 8rpx;
}
.line {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}
.line:last-child { border-bottom: none; }
.k { font-size: 24rpx; color: var(--text-secondary); }
.v { font-size: 28rpx; font-weight: 600; color: var(--text); font-variant-numeric: tabular-nums; }

.theme-light .lines { border-top-color: #eef2f7; }
.theme-light .line { border-bottom-color: #f1f5f9; }
.theme-light .v { color: #0f172a; }