.stage-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 24rpx 32rpx !important;
  text-align: center;
}

.stage-label {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: var(--accent);
  margin-bottom: 20rpx;
  font-weight: 600;
}

.stage-icon {
  margin-bottom: 18rpx;
  filter: drop-shadow(0 0 18rpx rgba(92, 225, 255, 0.35));
  transition: transform 0.2s ease;
}

.stage-icon.spin {
  animation: foodSpin 0.7s linear infinite;
}

.stage-result {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.35;
  min-height: 60rpx;
  letter-spacing: 1rpx;
  word-break: break-all;
  text-shadow: 0 0 24rpx rgba(92, 225, 255, 0.28);
}

.stage-result.blur {
  opacity: 0.72;
  filter: blur(1rpx);
}

.hist-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hist-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(0, 0, 0, 0.28);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.hist-idx {
  font-size: 20rpx;
  color: var(--accent);
  letter-spacing: 1rpx;
  min-width: 48rpx;
}

.hist-name {
  font-size: 28rpx;
  color: var(--text);
}

@keyframes foodSpin {
  0% { transform: rotate(-6deg) scale(0.96); }
  50% { transform: rotate(6deg) scale(1.04); }
  100% { transform: rotate(-6deg) scale(0.96); }
}

.theme-light .stage-icon {
  filter: none;
}
.theme-light .stage-result {
  text-shadow: none;
  color: #0f172a;
}
.theme-light .hist-item {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}
.theme-light .hist-name { color: #0f172a; }
