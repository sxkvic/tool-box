/* 自定义导航已占高度，不要再强制 100vh */
.med-page {
  min-height: 0;
  overflow-x: hidden;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.hero-card {
  padding-bottom: 20rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-count {
  font-size: 36rpx;
  font-weight: 650;
  color: var(--text);
  line-height: 1.25;
}

.hero-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.45;
}

.person-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
  width: 100%;
}

.person-chip {
  display: inline-block;
  padding: 10rpx 18rpx;
  margin-right: 10rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: transparent;
  vertical-align: middle;
  line-height: 1.3;
}

.person-chip.on {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.06);
  font-weight: 600;
}

.person-chip-tag {
  color: var(--accent);
  font-weight: 600;
  font-size: 20rpx;
}

.person-chip-due {
  color: #ffb020;
  font-weight: 600;
}

.person-hint {
  margin-top: 10rpx;
  font-size: 20rpx;
  color: var(--text-muted);
}

/* 记用药 / 记体温：并入顶部卡片底部一行 */
.hero-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.hero-action {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  padding: 8rpx 0;
  letter-spacing: 1rpx;
}

.hero-action-sep {
  width: 1rpx;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.12);
  flex-shrink: 0;
}

.hero-action-hover {
  color: var(--accent);
}

.sheet-belong {
  margin-bottom: 16rpx !important;
  color: var(--accent) !important;
  font-weight: 600;
}

.empty-inline {
  margin: 8rpx 0 0;
}

.footer-del {
  margin: 8rpx 0 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 16rpx;
}

.footer-del:active {
  color: #ff5c7a;
}



.field-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.field-col {
  flex: 1;
  min-width: 0;
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.field-tip {
  margin-top: 8rpx;
  margin-bottom: 0;
}

/* —— 用药：简约列表 —— */
.day-line {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 20rpx 0 8rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.day-line:first-child {
  margin-top: 12rpx;
}

.day-line-t {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 0.5rpx;
}

.day-line-n {
  font-size: 22rpx;
  color: var(--text-muted);
}

.med-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.med-row:last-child {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.med-row-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.med-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.4;
  word-break: break-all;
}

.med-del-text {
  flex-shrink: 0;
  width: 64rpx;
  text-align: right;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-muted);
}

.med-del-text:active {
  color: #ff5c7a;
}

.med-remain {
  display: block;
  margin-bottom: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
  line-height: 1.4;
}

.med-remain.warn {
  color: #ffb020;
}

.med-remain.danger {
  color: #ff5c7a;
}

.med-line {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.med-line.mute {
  color: var(--text-muted);
  font-size: 22rpx;
  margin-top: 2rpx;
}

.med-advice {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-muted);
  word-break: break-all;
}

.more-plain {
  margin-top: 8rpx;
  padding: 16rpx 0 4rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.more-plain:active {
  color: var(--accent);
}

.advice-input {
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

.chart-sub {
  margin-top: 12rpx;
  margin-bottom: 0;
}

.chart-wrap {
  width: 100%;
  max-width: 100%;
  overflow: hidden;
  margin-top: 8rpx;
  box-sizing: border-box;
}

.chart-canvas {
  width: 100%;
  max-width: 100%;
  height: 160px;
  display: block;
  box-sizing: border-box;
}

.chart-empty-tip {
  text-align: center;
  margin-top: 8rpx;
  margin-bottom: 0;
}

.sort-tabs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.sort-tab {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--text-muted);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
}

.sort-tab.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.35);
  background: rgba(92, 225, 255, 0.1);
  font-weight: 650;
}

.temp-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx 18rpx;
  margin: 14rpx 0 4rpx;
}

.chart-sub {
  margin: 8rpx 0 0;
  font-size: 22rpx;
}

.temp-preview-label {
  margin-top: 18rpx;
  margin-bottom: 8rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 1rpx;
}

.day-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 12rpx 0 4rpx;
  padding: 8rpx 0;
}

.day-head.mini {
  margin-top: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-bottom: 10rpx;
}

.day-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--accent);
}

.day-count {
  font-size: 20rpx;
  color: var(--text-muted);
}

.more-link {
  font-size: 22rpx;
  color: var(--text-muted);
  padding: 6rpx 4rpx;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}

.more-link-hover {
  color: var(--accent);
}

.more-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 72rpx;
  border-radius: 14rpx;
  font-size: 26rpx;
  font-weight: 650;
  color: var(--accent);
  background: rgba(92, 225, 255, 0.08);
  border: 1rpx solid rgba(92, 225, 255, 0.2);
}

.more-arrow {
  font-size: 32rpx;
  line-height: 1;
  opacity: 0.8;
}

.more-row-hover {
  opacity: 0.88;
  background: rgba(92, 225, 255, 0.14);
}

.legend-item {
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.temp-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  box-sizing: border-box;
}

.temp-item:last-child {
  border-bottom: none;
}

.temp-val {
  font-size: 30rpx;
  font-weight: 700;
  width: 120rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.temp-del-text {
  flex-shrink: 0;
  width: 64rpx;
  text-align: right;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-muted);
}

.temp-del-text:active {
  color: #ff5c7a;
}

.temp-normal {
  color: #3dff9a;
}

.temp-fever {
  color: #ff9f43;
}

.temp-high {
  color: #ff5c7a;
}

.temp-unknown {
  color: #8b95ad;
}

.temp-mid {
  flex: 1;
  min-width: 0;
}

.temp-time {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.temp-person {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--text-muted);
}

.empty-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-cta.ghost {
  color: var(--accent);
  background: transparent;
  border: 1rpx solid rgba(92, 225, 255, 0.35);
  box-shadow: none;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.chip {
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.04);
}

.chip.on {
  color: #07101c;
  border-color: transparent;
  background: linear-gradient(180deg, #f7fbff, #c8dcff);
  font-weight: 650;
}

.theme-light .chip {
  border-color: #e2e8f0;
  background: #ffffff;
  color: #64748b;
}

.theme-light .chip.on {
  color: #ffffff;
  background: linear-gradient(180deg, #3b82f6, #60a5fa);
}

.theme-light .empty-cta.ghost {
  color: #2563eb;
  border-color: #93c5fd;
}

.temp-del {
  font-size: 22rpx;
  color: #ff5c7a;
  padding: 8rpx;
  flex-shrink: 0;
}

.empty-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.empty-desc {
  margin: 0 0 24rpx !important;
  text-align: center;
}

.empty-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 220rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #07101c;
  background: linear-gradient(180deg, #f7fbff 0%, #c8dcff 100%);
  box-shadow: 0 6rpx 18rpx rgba(92, 225, 255, 0.22);
}

/* sheet · 对齐体重页 */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #121a2c, #0a101c);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 28rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-bottom: none;
  max-height: 85vh;
  overflow: hidden;
  box-sizing: border-box;
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  margin: 4rpx auto 18rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: var(--text);
}

.sheet-field {
  margin-bottom: 18rpx;
}

.sheet-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.sheet-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding-bottom: 8rpx;
}

.sheet-field-last {
  margin-bottom: 8rpx;
}

.sheet-actions {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  padding: 20rpx 0 calc(28rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent, rgba(5, 7, 12, 0.55) 28%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.sheet-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 92rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  white-space: nowrap;
  overflow: hidden;
  position: relative;
}

/* 取消：青描边幽灵，次要 */
.sheet-btn-cancel {
  flex: 0 0 28%;
  max-width: 200rpx;
  color: #c5d0e6;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(92, 225, 255, 0.22);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.sheet-btn-hover {
  background: rgba(92, 225, 255, 0.1) !important;
  border-color: rgba(92, 225, 255, 0.45) !important;
  color: #5ce1ff !important;
}

/* 保存：主 CTA，占主宽度 */
.sheet-btn-save {
  flex: 1 1 auto;
  min-width: 0;
  color: #07101c;
  background: linear-gradient(180deg, #f7fbff 0%, #d9e8ff 48%, #b8d0ff 100%);
  border: none;
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.35),
    0 10rpx 28rpx rgba(92, 225, 255, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.sheet-btn-save::before {
  content: '';
  position: absolute;
  left: 12%;
  right: 12%;
  top: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.95), transparent);
  pointer-events: none;
}

.sheet-btn-save-hover {
  opacity: 0.92;
  transform: scale(0.985) translateY(1rpx);
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.28),
    0 4rpx 14rpx rgba(92, 225, 255, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85) !important;
}

/* light */
.theme-light .person-chip {
  border-color: #e2e8f0;
  color: #64748b;
  background: transparent;
}

.theme-light .person-chip.on {
  border-color: #cbd5e1;
  background: #f8fafc;
  color: #0f172a;
}

.theme-light .person-chip-tag {
  color: #2563eb;
}

.theme-light .hero-actions {
  border-top-color: #eef2f7;
}

.theme-light .hero-action {
  color: #64748b;
}

.theme-light .hero-action-sep {
  background: #e2e8f0;
}

.theme-light .hero-action-hover {
  color: #2563eb;
}

.theme-light .hero-count {
  color: #0f172a;
}

.theme-light .day-line {
  border-bottom-color: #eef2f7;
}

.theme-light .day-line-t {
  color: #64748b;
}

.theme-light .med-row {
  border-bottom-color: #f1f5f9;
}

.theme-light .med-name {
  color: #0f172a;
}

.theme-light .med-remain {
  color: #64748b;
}

.theme-light .med-remain.warn {
  color: #d97706;
}

.theme-light .med-remain.danger {
  color: #e11d48;
}

.theme-light .med-line {
  color: #64748b;
}

.theme-light .med-line.mute,
.theme-light .med-advice {
  color: #94a3b8;
}

.theme-light .med-del-text {
  color: #94a3b8;
}

.theme-light .med-del-text:active {
  color: #e11d48;
}

.theme-light .more-plain {
  color: #64748b;
}

.theme-light .more-plain:active {
  color: #2563eb;
}

.theme-light .temp-item {
  border-bottom-color: #eef2f7;
}

.theme-light .sort-tab {
  border-color: #e2e8f0;
  background: #ffffff;
  color: #94a3b8;
}

.theme-light .sort-tab.on {
  color: #2563eb;
  border-color: #93c5fd;
  background: #eff6ff;
}

.theme-light .temp-normal {
  color: #059669;
}

.theme-light .temp-fever {
  color: #ea580c;
}

.theme-light .temp-high {
  color: #e11d48;
}

.theme-light .day-head.mini {
  border-bottom-color: #eef2f7;
}

.theme-light .day-label {
  color: #2563eb;
}

.theme-light .more-row {
  color: #2563eb;
  background: #eff6ff;
  border-color: #93c5fd;
}

.theme-light .more-link {
  color: #94a3b8;
}

.theme-light .more-link-hover {
  color: #2563eb;
}

.sheet.theme-light,
.theme-light.sheet {
  background: linear-gradient(180deg, #ffffff, #f5f7fb);
  border-color: #e2e8f0;
}

.sheet.theme-light .sheet-handle,
.theme-light.sheet .sheet-handle {
  background: rgba(15, 23, 42, 0.12);
}

.sheet.theme-light .sheet-actions,
.theme-light.sheet .sheet-actions {
  background: linear-gradient(180deg, transparent, rgba(245, 247, 251, 0.95) 30%);
  border-top-color: #eef2f7;
}

.sheet.theme-light .sheet-btn-cancel,
.theme-light.sheet .sheet-btn-cancel {
  color: #475569;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04);
}

.sheet.theme-light .sheet-btn-hover,
.theme-light.sheet .sheet-btn-hover {
  background: #eff6ff !important;
  border-color: #93c5fd !important;
  color: #2563eb !important;
}

.sheet.theme-light .sheet-btn-save,
.theme-light.sheet .sheet-btn-save {
  color: #ffffff;
  background: linear-gradient(180deg, #3b82f6 0%, #2563eb 100%);
  box-shadow:
    0 0 0 1rpx rgba(37, 99, 235, 0.25),
    0 10rpx 24rpx rgba(37, 99, 235, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.35);
}
