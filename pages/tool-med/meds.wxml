<page-meta
  background-text-style="{{bgTextStyle}}"
  background-color="{{chromeBg}}"
  root-background-color="{{chromeBg}}"
  page-style="background-color: {{chromeBg}};"
/>
<app-nav-bar
  title="用药明细"
  theme="{{theme}}"
  background="{{navBg}}"
  color="{{navFront}}"
  left="back"
/>
<view class="container theme-{{theme}} meds-page">
  <view class="card head-card">
    <view class="card-title-row">
      <view>
        <view class="head-name">{{personName || '成员'}}</view>
        <view class="head-sub">共 {{medCount}} 条</view>
      </view>
      <view class="sort-tabs" wx:if="{{medCount}}">
        <view
          class="sort-tab {{medSort === 'desc' ? 'on' : ''}}"
          data-order="desc"
          bindtap="onSetMedSort"
        >倒序</view>
        <view
          class="sort-tab {{medSort === 'asc' ? 'on' : ''}}"
          data-order="asc"
          bindtap="onSetMedSort"
        >升序</view>
      </view>
    </view>
  </view>

  <view class="card empty-card" wx:if="{{empty}}">
    <view class="empty-title">暂无用药记录</view>
    <view class="section-tip empty-desc">返回上一页添加</view>
  </view>

  <block wx:for="{{dayGroups}}" wx:key="date" wx:for-item="day">
    <view class="card day-card">
      <view class="day-line">
        <text class="day-line-t">{{day.dateLabel}}</text>
        <text class="day-line-n">{{day.count}}</text>
      </view>
      <view class="med-row" wx:for="{{day.items}}" wx:key="id" wx:for-item="item">
        <view class="med-row-top">
          <text class="med-name">{{item.medicineName}}</text>
          <text class="med-del-text" data-id="{{item.id}}" catchtap="onDeleteMed">删除</text>
        </view>
        <view class="med-remain {{item.remainDue ? (item.remainOverdue ? 'danger' : 'warn') : ''}}">{{item.remainText}}</view>
        <view class="med-line">{{item.timeOnly}} · 每 {{item.intervalText}}</view>
        <view class="med-line mute">下次 {{item.nextDoseText}}</view>
        <view class="med-advice" wx:if="{{item.advice}}">{{item.advice}}</view>
      </view>
    </view>
  </block>
</view>
