.meds-page {
  min-height: 0;
  overflow-x: hidden;
  box-sizing: border-box;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.card-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.head-name {
  font-size: 34rpx;
  font-weight: 650;
  color: var(--text);
  line-height: 1.3;
}

.head-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-muted);
}

.sort-tabs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.sort-tab {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: var(--text-muted);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  background: transparent;
}

.sort-tab.on {
  color: var(--text);
  border-color: rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.06);
  font-weight: 600;
}

.day-card {
  padding-top: 20rpx;
  padding-bottom: 12rpx;
}

.day-line {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 4rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.day-line-t {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.day-line-n {
  font-size: 22rpx;
  color: var(--text-muted);
}

.med-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.med-row:last-child {
  border-bottom: none;
}

.med-row-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.med-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  line-height: 1.4;
  word-break: break-all;
}

.med-del-text {
  flex-shrink: 0;
  width: 64rpx;
  text-align: right;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-muted);
}

.med-del-text:active {
  color: #ff5c7a;
}

.med-remain {
  display: block;
  margin-bottom: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
  line-height: 1.4;
}

.med-remain.warn {
  color: #ffb020;
}

.med-remain.danger {
  color: #ff5c7a;
}

.med-line {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.med-line.mute {
  color: var(--text-muted);
  font-size: 22rpx;
  margin-top: 2rpx;
}

.med-advice {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-muted);
  word-break: break-all;
}

.empty-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  color: var(--text);
}

.empty-desc {
  margin: 0 !important;
  text-align: center;
}

.theme-light .sort-tab {
  border-color: #e2e8f0;
  color: #94a3b8;
}

.theme-light .sort-tab.on {
  color: #0f172a;
  border-color: #cbd5e1;
  background: #f8fafc;
}

.theme-light .day-line {
  border-bottom-color: #eef2f7;
}

.theme-light .day-line-t {
  color: #64748b;
}

.theme-light .med-row {
  border-bottom-color: #f1f5f9;
}

.theme-light .med-name {
  color: #0f172a;
}

.theme-light .med-remain {
  color: #64748b;
}

.theme-light .med-remain.warn {
  color: #d97706;
}

.theme-light .med-remain.danger {
  color: #e11d48;
}

.theme-light .med-line {
  color: #64748b;
}

.theme-light .med-line.mute,
.theme-light .med-advice {
  color: #94a3b8;
}

.theme-light .med-del-text {
  color: #94a3b8;
}

.theme-light .med-del-text:active {
  color: #e11d48;
}

.theme-light .head-name {
  color: #0f172a;
}
