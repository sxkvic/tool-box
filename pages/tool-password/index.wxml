<view class="container theme-{{theme}}">
  <quota-bar id="quotaBar" />

  <view class="card rules-card">
    <view class="card-title">自定义规则</view>

    <view class="section-label">快捷预设</view>
    <view class="tag-row preset-row">
      <view
        class="tag {{preset === item.key ? 'active' : ''}}"
        wx:for="{{presets}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onPreset"
      >{{item.name}}</view>
    </view>

    <view class="section-label">密码长度 · {{length}} 位</view>
    <view class="len-chips">
      <view
        class="len-chip {{length === item ? 'on' : ''}}"
        wx:for="{{lengthOptions}}"
        wx:key="*this"
        data-len="{{item}}"
        bindtap="onLengthTap"
      >{{item}}</view>
    </view>
    <view class="len-custom">
      <view class="len-btn" data-delta="-1" bindtap="onLengthStep">-</view>
      <slider
        class="len-slider"
        min="4"
        max="64"
        step="1"
        value="{{length}}"
        activeColor="{{theme === 'light' ? '#2563eb' : '#5ce1ff'}}"
        backgroundColor="{{theme === 'light' ? '#e2e8f0' : 'rgba(255,255,255,0.12)'}}"
        block-size="18"
        bindchange="onLengthSlider"
        bindchanging="onLengthSliding"
      />
      <view class="len-btn" data-delta="1" bindtap="onLengthStep">+</view>
    </view>

    <view class="section-label">字符类型</view>
    <view class="opt-grid">
      <view class="opt {{lower ? 'on' : ''}}" data-key="lower" bindtap="onToggle">
        <text class="opt-k">a-z</text>
        <text class="opt-v">小写</text>
      </view>
      <view class="opt {{upper ? 'on' : ''}}" data-key="upper" bindtap="onToggle">
        <text class="opt-k">A-Z</text>
        <text class="opt-v">大写</text>
      </view>
      <view class="opt {{digit ? 'on' : ''}}" data-key="digit" bindtap="onToggle">
        <text class="opt-k">0-9</text>
        <text class="opt-v">数字</text>
      </view>
      <view class="opt {{symbol ? 'on' : ''}}" data-key="symbol" bindtap="onToggle">
        <text class="opt-k">#@!</text>
        <text class="opt-v">符号</text>
      </view>
    </view>

    <view class="switch-row" bindtap="onToggleExclude">
      <view class="switch-meta">
        <text class="switch-title">排除易混字符</text>
        <text class="switch-desc">过滤 0 / O / I / l / 1 等</text>
      </view>
      <view class="switch-ui {{excludeAmbiguous ? 'on' : ''}}">
        <view class="switch-knob"></view>
      </view>
    </view>

    <view class="section-tip rules-tip">仅在本机生成，不上传服务器 · 支持 4-64 位自定义</view>
    <view class="card-actions single">
      <view
        class="btn-primary action-btn {{generating ? 'is-disabled' : ''}}"
        hover-class="btn-primary-hover"
        bindtap="onGenerate"
      >{{generating ? '生成中...' : '生成密码'}}</view>
    </view>
  </view>

  <view class="result-box" wx:if="{{password}}">
    <view class="result-label">生成结果</view>
    <view class="pwd-line">{{password}}</view>
    <view class="str-row">
      <text class="str-label">强度</text>
      <view class="str-bars">
        <view class="str-bar {{strengthLevel >= 1 ? 'on' : ''}}"></view>
        <view class="str-bar {{strengthLevel >= 2 ? 'on' : ''}}"></view>
        <view class="str-bar {{strengthLevel >= 3 ? 'on' : ''}}"></view>
        <view class="str-bar {{strengthLevel >= 4 ? 'on' : ''}}"></view>
      </view>
      <text class="str-text" style="color: {{strengthColor}};">{{strengthLabel}}</text>
    </view>
    <view class="card-actions">
      <view class="btn-ghost action-btn" hover-class="btn-ghost-hover" bindtap="onCopy">复制密码</view>
      <view
        class="btn-primary action-btn {{generating ? 'is-disabled' : ''}}"
        hover-class="btn-primary-hover"
        bindtap="onGenerate"
      >{{generating ? '生成中...' : '重新生成'}}</view>
    </view>
  </view>

  <view class="card" wx:if="{{history.length}}">
    <view class="card-title">最近生成</view>
    <view class="hist" wx:for="{{history}}" wx:key="*this" data-v="{{item}}" bindtap="onCopyHist">
      <text class="hist-pwd">{{item}}</text>
      <text class="hist-copy">复制</text>
    </view>
  </view>

  <view class="ad-slot"><ad-banner /></view>
</view>
