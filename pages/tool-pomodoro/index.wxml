<view class="container theme-{{theme}}">
  <quota-bar free="{{true}}" />

  <view class="card timer-card">
    <view class="phase-chip phase-{{phase}}">{{phaseText}}</view>

    <view class="ring-wrap">
      <view class="ring-glow phase-{{phase}}"></view>
      <view class="ring-face">
        <view class="timer-text">{{timeText}}</view>
        <view class="timer-sub">{{running ? '进行中' : (remainSec === totalSec ? '准备开始' : '已暂停')}}</view>
      </view>
    </view>

    <view class="progress-track">
      <view class="progress-fill phase-{{phase}}" style="width: {{progress}}%;"></view>
    </view>

    <view class="meta-row">
      <view class="meta-item">
        <text class="meta-num">{{doneRounds}}</text>
        <text class="meta-label">已完成</text>
      </view>
      <view class="meta-divider"></view>
      <view class="meta-item">
        <text class="meta-num">{{workMin}}</text>
        <text class="meta-label">专注分</text>
      </view>
      <view class="meta-divider"></view>
      <view class="meta-item">
        <text class="meta-num">{{restMin}}</text>
        <text class="meta-label">休息分</text>
      </view>
    </view>

    <view class="action-row">
      <view
        class="action-btn primary {{running ? '' : ''}}"
        hover-class="action-btn-hover"
        bindtap="onToggleRun"
      >{{running ? '暂停' : (remainSec === totalSec ? '开始' : '继续')}}</view>
      <view class="action-btn ghost" hover-class="action-btn-hover" bindtap="onReset">重置</view>
    </view>

    <view
      class="skip-btn {{running ? 'disabled' : ''}}"
      hover-class="{{running ? '' : 'skip-btn-hover'}}"
      bindtap="skipPhase"
    >跳过本阶段</view>
  </view>

  <view class="card">
    <view class="card-title">预设节奏</view>
    <view class="preset-grid">
      <view
        class="preset-item {{preset === item.key ? 'on' : ''}} {{running ? 'locked' : ''}}"
        wx:for="{{presets}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onPreset"
      >
        <text class="preset-name">{{item.name}}</text>
        <text class="preset-time">{{item.work}} / {{item.rest}}</text>
      </view>
    </view>
  </view>

  <view class="card tip-card">
    <view class="card-title">使用提示</view>
    <view class="tip-text">保持屏幕常亮可避免后台节流。本工具纯本地计时，不消耗每日次数。</view>
  </view>

  <view class="ad-slot"><ad-banner /></view>
</view>
