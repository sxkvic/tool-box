.timer-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 28rpx 32rpx !important;
  text-align: center;
}

.phase-chip {
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  margin-bottom: 18rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.35);
  color: #5ce1ff;
  background: rgba(92, 225, 255, 0.1);
}

.phase-chip.phase-rest {
  color: #3dff9a;
  border-color: rgba(61, 255, 154, 0.35);
  background: rgba(61, 255, 154, 0.1);
}

.timer-text {
  font-size: 104rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  line-height: 1.1;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 0 36rpx rgba(92, 225, 255, 0.28);
  margin-bottom: 28rpx;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
  margin-bottom: 18rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5ce1ff, #7c9cff);
  box-shadow: 0 0 16rpx rgba(92, 225, 255, 0.45);
  transition: width 0.3s linear;
}

.meta-row {
  width: 100%;
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.flex-1 {
  flex: 1;
  margin-top: 0 !important;
}

.tip-card .section-tip {
  line-height: 1.6;
}

.theme-light .timer-text {
  text-shadow: none;
  color: #0f172a;
}
.theme-light .progress-track {
  background: #e2e8f0;
}
.theme-light .progress-fill {
  background: linear-gradient(90deg, #3b82f6, #60a5fa);
  box-shadow: none;
}
.theme-light .phase-chip {
  background: #eff6ff;
  border-color: #93c5fd;
  color: #2563eb;
}
.theme-light .phase-chip.phase-rest {
  background: #ecfdf5;
  border-color: #6ee7b7;
  color: #059669;
}
