.sep {
  color: #5a6478;
  padding: 0 8rpx;
  font-size: 28rpx;
}

.dice-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 24rpx !important;
}

.dice-face {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  line-height: 1;
  margin-bottom: 12rpx;
  filter: drop-shadow(0 0 16rpx rgba(92, 225, 255, 0.35));
  animation: floatGlow 2.4s ease-in-out infinite;
}

.result-value.big {
  font-size: 64rpx;
  text-align: center;
  margin: 8rpx 0 4rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 0 28rpx rgba(92, 225, 255, 0.35);
}

@keyframes floatGlow {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}
.result-box .btn-ghost {
  width: 100%;
  height: 72rpx !important;
  line-height: 72rpx !important;
  box-sizing: border-box;
  letter-spacing: 2rpx;
}

/* Clean Lab */
.theme-light .sep { color: #94a3b8; }
.theme-light .result-value.big {
  text-shadow: none;
  color: #0f172a;
}
.theme-light .dice-face {
  filter: none;
}
.theme-light .result-box .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
}