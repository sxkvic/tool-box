.path-box {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx;
  min-height: 64rpx;
  margin-bottom: 16rpx;
  padding: 14rpx 16rpx;
  background: rgba(0, 0, 0, 0.32);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.path-chip {
  padding: 8rpx 14rpx;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border-radius: 8rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.path-chip.me {
  background: rgba(92, 225, 255, 0.18);
  color: #9ef0ff;
  border-color: rgba(92, 225, 255, 0.5);
  box-shadow: 0 0 14rpx rgba(92, 225, 255, 0.14);
  font-weight: 700;
}

.path-arrow {
  color: #8b95ad;
  font-size: 22rpx;
}

.rel-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

/* 关系键位：高对比白字 + 深底 */
.rel-btn {
  position: relative;
  width: calc(33.33% - 8rpx);
  box-sizing: border-box;
  text-align: center;
  padding: 24rpx 8rpx;
  background: linear-gradient(180deg, rgba(36, 48, 72, 0.98), rgba(18, 24, 40, 0.98));
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff !important;
  letter-spacing: 2rpx;
  border: 1rpx solid rgba(148, 180, 220, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1),
    0 6rpx 14rpx rgba(0, 0, 0, 0.28);
  overflow: hidden;
}

.rel-btn::before {
  content: '';
  position: absolute;
  left: 16%;
  right: 16%;
  top: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(158, 240, 255, 0.55), transparent);
  pointer-events: none;
}

.rel-btn:active {
  transform: scale(0.97);
  background: linear-gradient(180deg, rgba(40, 90, 120, 0.95), rgba(20, 40, 60, 0.98));
  color: #9ef0ff !important;
  border-color: rgba(92, 225, 255, 0.65);
  box-shadow:
    0 0 20rpx rgba(92, 225, 255, 0.22),
    inset 0 0 16rpx rgba(92, 225, 255, 0.1);
}

/* 底部操作行 */
.row-btns {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  align-items: stretch;
}

.flex-btn {
  flex: 1;
  margin: 0 !important;
  min-width: 0;
  padding: 0 8rpx !important;
}

/* ghost：白字 + 清晰描边，避免发灰看不清 */
.row-btns .btn-ghost.flex-btn,
.row-btns .btn-ghost {
  height: 80rpx !important;
  line-height: 80rpx !important;
  font-size: 26rpx !important;
  font-weight: 700 !important;
  letter-spacing: 2rpx !important;
  color: #f4f7ff !important;
  background: linear-gradient(180deg, rgba(40, 52, 78, 0.95), rgba(22, 30, 48, 0.95)) !important;
  border: 1rpx solid rgba(180, 210, 240, 0.32) !important;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.08),
    0 4rpx 12rpx rgba(0, 0, 0, 0.22) !important;
}

.row-btns .btn-ghost.flex-btn:active,
.row-btns .btn-ghost:active {
  color: #9ef0ff !important;
  border-color: rgba(92, 225, 255, 0.6) !important;
  background: rgba(30, 60, 90, 0.95) !important;
}

/* disabled ghost：仍可读，不要整片消失 */
.row-btns .btn-ghost[disabled],
.row-btns .btn-ghost.flex-btn[disabled] {
  opacity: 1 !important;
  color: #6b758c !important;
  background: rgba(18, 22, 34, 0.9) !important;
  border-color: rgba(255, 255, 255, 0.08) !important;
  box-shadow: none !important;
}

/* 主按钮：深字 + 亮底，禁用时改为暗底浅字避免看不清 */
.row-btns .btn-primary.flex-btn,
.row-btns .btn-primary,
.flex-btn.calc {
  height: 80rpx !important;
  line-height: 80rpx !important;
  margin-top: 0 !important;
  font-size: 26rpx !important;
  font-weight: 800 !important;
  letter-spacing: 2rpx !important;
  color: #061018 !important;
  background: linear-gradient(180deg, #f5fbff 0%, #d7e9ff 50%, #bfd8ff 100%) !important;
  border: 1rpx solid rgba(180, 220, 255, 0.9) !important;
  box-shadow:
    0 0 0 1rpx rgba(92, 225, 255, 0.25),
    0 8rpx 20rpx rgba(92, 225, 255, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9) !important;
}

.row-btns .btn-primary[disabled],
.row-btns .btn-primary.flex-btn[disabled],
.flex-btn.calc[disabled] {
  opacity: 1 !important;
  color: #8b95ad !important;
  background: linear-gradient(180deg, rgba(40, 48, 68, 0.95), rgba(24, 30, 46, 0.95)) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.1) !important;
  box-shadow: none !important;
}

/* Clean Lab · 亲戚称呼 */
.theme-light .path-box {
  background: #f8fafc;
  border: none;
  border-radius: 14rpx;
}

.theme-light .path-chip {
  background: #ffffff;
  color: #0f172a;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 2rpx 8rpx rgba(15, 23, 42, 0.03);
}

.theme-light .path-chip.me {
  background: #dbeafe;
  color: #1d4ed8;
  border: none;
  box-shadow: none;
  font-weight: 700;
}

.theme-light .path-arrow {
  color: #94a3b8;
}

.theme-light .rel-btn {
  background: #ffffff !important;
  color: #0f172a !important;
  border: 1rpx solid #e2e8f0 !important;
  border-radius: 16rpx !important;
  font-weight: 700 !important;
  box-shadow: 0 6rpx 16rpx rgba(15, 23, 42, 0.04) !important;
}

.theme-light .rel-btn::before {
  display: none;
}

.theme-light .rel-btn:active {
  transform: scale(0.97);
  background: #eff6ff !important;
  color: #2563eb !important;
  border-color: #bfdbfe !important;
  box-shadow: 0 4rpx 12rpx rgba(37, 99, 235, 0.08) !important;
}

.theme-light .row-btns .btn-ghost.flex-btn,
.theme-light .row-btns .btn-ghost {
  color: #334155 !important;
  background: #ffffff !important;
  border: 1rpx solid #e2e8f0 !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04) !important;
}

.theme-light .row-btns .btn-ghost:active {
  color: #2563eb !important;
  background: #eff6ff !important;
  border-color: #bfdbfe !important;
}

.theme-light .row-btns .btn-ghost[disabled],
.theme-light .row-btns .btn-ghost.flex-btn[disabled] {
  color: #94a3b8 !important;
  background: #f8fafc !important;
  border-color: #e2e8f0 !important;
  box-shadow: none !important;
}

.theme-light .row-btns .btn-primary.flex-btn,
.theme-light .row-btns .btn-primary,
.theme-light .flex-btn.calc {
  color: #ffffff !important;
  background: linear-gradient(180deg, #3b82f6 0%, #2563eb 55%, #1d4ed8 100%) !important;
  border: none !important;
  box-shadow: 0 8rpx 18rpx rgba(37, 99, 235, 0.22) !important;
}

.theme-light .row-btns .btn-primary[disabled],
.theme-light .row-btns .btn-primary.flex-btn[disabled],
.theme-light .flex-btn.calc[disabled] {
  color: #94a3b8 !important;
  background: #e2e8f0 !important;
  border: none !important;
  box-shadow: none !important;
}