.stats {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 8rpx 0 20rpx;
}

.stat-item {
  width: calc(50% - 6rpx);
  box-sizing: border-box;
  background: linear-gradient(160deg, rgba(16, 24, 42, 0.95), rgba(8, 12, 22, 0.95));
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 1rpx solid rgba(92, 225, 255, 0.16);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
  animation: resultIn 0.4s cubic-bezier(0.22, 1, 0.36, 1) both;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #5ce1ff;
  font-variant-numeric: tabular-nums;
  line-height: 1.15;
  text-shadow: 0 0 18rpx rgba(92, 225, 255, 0.3);
}

.stat-label {
  margin-top: 8rpx;
  font-size: 18rpx;
  color: #8b95ad;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* 全宽动作按钮：快捷处理面板 */
.block {
  position: relative;
  display: block;
  width: 100%;
  margin: 0 0 14rpx !important;
  height: 80rpx !important;
  line-height: 80rpx !important;
  border-radius: 12rpx !important;
  font-size: 26rpx !important;
  letter-spacing: 2rpx !important;
  overflow: hidden;
}

.block:last-child {
  margin-bottom: 0 !important;
}

/* 强化 ghost 全宽按钮的控制台感（覆盖组件内联观感） */
.card .btn-ghost.block {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.015)) !important;
  border: 1rpx solid rgba(92, 225, 255, 0.22) !important;
  color: #e8f1ff !important;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.06),
    0 4rpx 14rpx rgba(0, 0, 0, 0.16) !important;
}

.card .btn-ghost.block:active {
  background: rgba(92, 225, 255, 0.12) !important;
  border-color: rgba(92, 225, 255, 0.55) !important;
  color: #5ce1ff !important;
  box-shadow: 0 0 18rpx rgba(92, 225, 255, 0.14) !important;
}

@keyframes resultIn {
  from { opacity: 0; transform: translateY(12rpx) scale(0.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

/* Clean Lab */
.theme-light .stat-item {
  background: #ffffff;
  border: none;
  border-radius: 18rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}
.theme-light .stat-num {
  color: #2563eb;
  text-shadow: none;
}
.theme-light .stat-label { color: #94a3b8; }
.theme-light .card .btn-ghost.block {
  background: #ffffff !important;
  border: 1rpx solid #e2e8f0 !important;
  color: #334155 !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04) !important;
  border-radius: 14rpx !important;
}
.theme-light .card .btn-ghost.block:active {
  background: #eff6ff !important;
  color: #2563eb !important;
  border-color: #bfdbfe !important;
}