.now-line {
  font-size: 34rpx;
  font-weight: 700;
  color: #f4f7ff;
  margin-bottom: 16rpx;
  word-break: break-all;
  letter-spacing: 1rpx;
  text-shadow: 0 0 20rpx rgba(92, 225, 255, 0.2);
}

.ts-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 4rpx;
}

.ts-cell {
  flex: 1;
  min-width: 0;
  padding: 16rpx 18rpx;
  background: rgba(0, 0, 0, 0.28);
  border-radius: 12rpx;
  border: 1rpx solid rgba(92, 225, 255, 0.14);
}

.ts-label {
  font-size: 18rpx;
  color: #5ce1ff;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.ts-val {
  font-size: 24rpx;
  color: #f4f7ff;
  font-weight: 600;
  word-break: break-all;
  font-variant-numeric: tabular-nums;
}

.row-btns {
  gap: 12rpx;
}

.flex-btn {
  font-size: 22rpx !important;
  height: 72rpx !important;
  line-height: 72rpx !important;
  letter-spacing: 1rpx !important;
  padding: 0 8rpx !important;
}

/* 结果区内次按钮 */
.result-box .btn-ghost {
  height: 72rpx !important;
  line-height: 72rpx !important;
  border-radius: 12rpx !important;
  width: 100%;
  box-sizing: border-box;
}

.result-box.compact {
  margin-top: 20rpx;
  margin-bottom: 0;
}

.result-value.small {
  font-size: 30rpx;
}

/* Clean Lab */
.theme-light .now-line {
  color: #0f172a;
  text-shadow: none;
}
.theme-light .ts-cell {
  background: #f8fafc;
  border: none;
  border-radius: 14rpx;
}
.theme-light .ts-label { color: #2563eb; }
.theme-light .ts-val { color: #0f172a; }
.theme-light .result-box .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
}