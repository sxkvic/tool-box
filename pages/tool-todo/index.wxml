<view class="container theme-{{theme}}">
  <quota-bar free="{{true}}" />

  <view class="card">
    <view class="card-title">新建待办</view>
    <view class="row">
      <input class="input flex-1" placeholder="例如：晚上健身 30 分钟" value="{{text}}" bindinput="onText" confirm-type="done" bindconfirm="onAdd" />
    </view>
    <button class="btn-primary" bindtap="onAdd">添加</button>
  </view>

  <view class="card">
    <view class="card-title">列表 · 剩余 {{leftCount}}</view>
    <view class="tag-row" style="margin-bottom: 12rpx;">
      <view
        class="tag {{filter === item.key ? 'active' : ''}}"
        wx:for="{{filters}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onFilter"
      >{{item.name}}</view>
    </view>

    <block wx:if="{{viewItems.length}}">
      <view class="todo-item {{item.done ? 'done' : ''}}" wx:for="{{viewItems}}" wx:key="id">
        <view class="check {{item.done ? 'on' : ''}}" data-id="{{item.id}}" bindtap="onToggle">{{item.done ? '✓' : ''}}</view>
        <view class="todo-text" data-id="{{item.id}}" bindtap="onToggle">{{item.text}}</view>
        <view class="todo-del" data-id="{{item.id}}" bindtap="onDelete">删除</view>
      </view>
    </block>
    <view class="section-tip" wx:else style="margin: 12rpx 0 0;">这一页还是空的</view>

    <button class="btn-ghost" style="margin-top: 18rpx; width: 100%;" bindtap="onClearDone" wx:if="{{items.length}}">清理已完成</button>
  </view>

  <view class="ad-slot"><ad-banner /></view>
</view>