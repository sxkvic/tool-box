.unit-pick {
  min-width: 180rpx;
  text-align: center;
  font-size: 26rpx !important;
  padding: 0 18rpx !important;
}

.swap-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 0;
}

.swap-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(92, 225, 255, 0.35), transparent);
}

.swap-badge {
  padding: 6rpx 14rpx;
  font-size: 18rpx;
  color: #5ce1ff;
  letter-spacing: 2rpx;
  text-transform: uppercase;
  background: rgba(92, 225, 255, 0.1);
  border: 1rpx solid rgba(92, 225, 255, 0.25);
  border-radius: 999rpx;
}
.result-box .btn-ghost {
  width: 100%;
  height: 72rpx !important;
  line-height: 72rpx !important;
  box-sizing: border-box;
}

/* Clean Lab */
.theme-light .swap-line {
  background: linear-gradient(90deg, transparent, rgba(37, 99, 235, 0.22), transparent);
}
.theme-light .swap-badge {
  color: #2563eb;
  background: #eff6ff;
  border: none;
}
.theme-light .result-box .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
}