.diet-page .day-bar { padding: 12rpx 16rpx; }
.day-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.day-btn {
  width: 64rpx;
  height: 64rpx;
  line-height: 60rpx;
  text-align: center;
  font-size: 40rpx;
  color: var(--accent);
  border-radius: 14rpx;
  background: rgba(255,255,255,0.04);
}
.day-center { text-align: center; min-width: 240rpx; }
.day-label { display: block; font-size: 30rpx; font-weight: 700; }
.day-date { display: block; font-size: 22rpx; color: var(--text-secondary); margin-top: 2rpx; }

.kcal-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}
.kcal-title { font-size: 22rpx; color: var(--accent); letter-spacing: 2rpx; font-weight: 600; }
.kcal-sub { margin-top: 8rpx; font-size: 22rpx; color: var(--text-secondary); max-width: 480rpx; }
.link-btn { font-size: 24rpx; color: var(--accent); }
.kcal-nums {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin: 18rpx 0 14rpx;
  gap: 12rpx;
}
.kcal-n { font-size: 64rpx; font-weight: 800; font-variant-numeric: tabular-nums; line-height: 1; }
.kcal-u { margin-left: 8rpx; font-size: 24rpx; color: var(--text-secondary); }
.remain { font-size: 24rpx; font-weight: 700; padding-bottom: 8rpx; }
.tone-ok { color: #4ade80; }
.tone-over { color: #f87171; }
.prog-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.08);
  overflow: hidden;
}
.prog-track.thin { height: 10rpx; }
.prog-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5ce1ff, #7c9cff);
}
.prog-fill.p { background: linear-gradient(90deg, #34d399, #6ee7b7); }
.prog-fill.f { background: linear-gradient(90deg, #fbbf24, #fcd34d); }
.prog-fill.c { background: linear-gradient(90deg, #60a5fa, #93c5fd); }
.meta-row {
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
  font-size: 20rpx;
  color: var(--text-muted);
}

.macro-item { margin-bottom: 18rpx; }
.macro-item:last-child { margin-bottom: 0; }
.macro-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}
.macro-name { color: var(--text-secondary); }
.macro-val { font-weight: 700; font-variant-numeric: tabular-nums; }

.meal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.meal-left { display: flex; align-items: center; gap: 14rpx; }
.meal-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  color: var(--accent);
  background: rgba(92,225,255,0.1);
  border: 1rpx solid rgba(92,225,255,0.25);
}
.meal-name { font-size: 28rpx; font-weight: 700; }
.meal-kcal { font-size: 22rpx; color: var(--text-secondary); }
.add-pill {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 700;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(92,225,255,0.35);
  background: rgba(92,225,255,0.08);
}
.meal-empty {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx 0 4rpx;
}
.food-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255,255,255,0.06);
}
.food-main { min-width: 0; flex: 1; }
.food-name { display: block; font-size: 28rpx; font-weight: 600; }
.food-sub { display: block; margin-top: 4rpx; font-size: 22rpx; color: var(--text-secondary); }
.food-right { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }
.food-kcal { font-size: 28rpx; font-weight: 800; font-variant-numeric: tabular-nums; }
.food-del { font-size: 22rpx; color: #f87171; padding: 8rpx; }

.disclaimer {
  margin: 8rpx 8rpx 24rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.theme-light .day-btn { background: #f1f5f9; }
.theme-light .prog-track { background: #e2e8f0; }
.theme-light .tone-ok { color: #16a34a; }
.theme-light .tone-over { color: #e11d48; }
.theme-light .meal-badge {
  background: #eff6ff;
  border-color: #bfdbfe;
  color: #2563eb;
}
.theme-light .add-pill {
  background: #eff6ff;
  border-color: #bfdbfe;
  color: #2563eb;
}
.theme-light .food-row { border-top-color: #eef2f7; }
.theme-light .food-del { color: #e11d48; }
.theme-light .prog-fill { background: linear-gradient(90deg, #3b82f6, #60a5fa); }

.food-row {
  align-items: center;
}
.food-thumb {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.16);
}
.food-emoji {
  font-size: 32rpx;
  line-height: 1;
}
.theme-light .food-thumb {
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}
