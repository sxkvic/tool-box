.weight-page {
  padding-bottom: 24rpx;
}

.hero-card {
  overflow: hidden;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.hero-label {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: var(--accent);
  font-weight: 600;
}

.link-btn {
  font-size: 24rpx;
  color: var(--accent);
  padding: 8rpx 4rpx;
}

.hero-main {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 8rpx;
}

.hero-num {
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -2rpx;
  font-variant-numeric: tabular-nums;
}

.hero-unit {
  margin-left: 8rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.hero-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  padding-bottom: 10rpx;
}

.delta-pill,
.bmi-pill {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(0, 0, 0, 0.25);
}

.tone-up { color: #f87171; }
.tone-down { color: #4ade80; }
.tone-flat { color: var(--text-secondary); }
.tone-mute { color: var(--text-muted); }

.hero-tip {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 次级记录入口：不抢体重数字的主视觉 */
.hero-cta {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(92, 225, 255, 0.10), rgba(124, 156, 255, 0.06));
  border: 1rpx solid rgba(92, 225, 255, 0.18);
  box-sizing: border-box;
}

.hero-cta-hover {
  opacity: 0.88;
  background: linear-gradient(135deg, rgba(92, 225, 255, 0.16), rgba(124, 156, 255, 0.10));
}

.hero-cta-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 500;
  line-height: 1;
  color: var(--accent);
  background: rgba(92, 225, 255, 0.12);
  border: 1rpx solid rgba(92, 225, 255, 0.22);
  flex-shrink: 0;
}

.hero-cta-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hero-cta-title {
  font-size: 28rpx;
  font-weight: 650;
  color: var(--text);
  letter-spacing: 1rpx;
}

.hero-cta-sub {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.hero-cta-arrow {
  font-size: 34rpx;
  color: rgba(92, 225, 255, 0.55);
  line-height: 1;
  padding-right: 4rpx;
}

.empty-cta {
  margin-top: 8rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 200rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--accent);
  background: rgba(92, 225, 255, 0.08);
  border: 1rpx solid rgba(92, 225, 255, 0.22);
}

.goal-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.goal-kv {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.goal-kv.right { align-items: flex-end; }

.goal-k {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.goal-v {
  font-size: 36rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.prog-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.prog-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5ce1ff, #7c9cff);
  box-shadow: 0 0 12rpx rgba(92, 225, 255, 0.35);
  transition: width 0.25s ease;
}

.goal-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--text);
}

.goal-sub.muted {
  color: var(--text-secondary);
  font-size: 22rpx;
  margin-top: 6rpx;
}

.goal-done {
  margin-top: 12rpx;
  color: #4ade80;
  font-size: 24rpx;
  font-weight: 600;
}

.empty-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: var(--text-secondary);
  font-size: 26rpx;
  padding: 8rpx 0 4rpx;
}

.empty-inline .arrow {
  font-size: 36rpx;
  color: var(--accent);
}

.card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.range-tabs {
  display: flex;
  gap: 8rpx;
}

.range-tab {
  font-size: 22rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.range-tab.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.4);
  background: rgba(92, 225, 255, 0.1);
  font-weight: 700;
}

.chart-canvas {
  width: 100%;
  display: block;
  margin: 4rpx 0 8rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 8rpx;
}

.stat-item {
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.stat-k {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.stat-v {
  font-size: 32rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.health-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx;
}

.health-box {
  padding: 16rpx 12rpx;
  border-radius: 14rpx;
  background: rgba(0, 0, 0, 0.22);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.health-k {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.health-v {
  font-size: 36rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.health-v.sm {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.3;
}

.health-s {
  font-size: 20rpx;
  color: var(--text-muted);
}

.level-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.55;
  padding: 16rpx 18rpx;
  background: rgba(0, 0, 0, 0.22);
  border-radius: 12rpx;
}

.disclaimer {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.empty-block {
  padding: 28rpx 8rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.rec-list {
  margin-top: 8rpx;
}

.rec-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.06);
}

.rec-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.rec-left {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rec-date {
  font-size: 28rpx;
  font-weight: 600;
}

.rec-time {
  font-size: 22rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rec-right {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.rec-w {
  font-size: 34rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.rec-u {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.rec-bf {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: var(--accent);
}

/* sheet */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #121a2c, #0a101c);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 28rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-bottom: none;
  transform: translateY(110%);
  transition: transform 0.28s ease, bottom 0.18s ease, max-height 0.18s ease;
  max-height: 85vh;
  overflow: hidden;
  box-sizing: border-box;
}

.sheet.on {
  transform: translateY(0);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  margin: 4rpx auto 18rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.sheet-field {
  margin-bottom: 18rpx;
}

.sheet-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.sheet-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding-bottom: 8rpx;
}

.sheet-field-last {
  margin-bottom: 8rpx;
}

.sheet-actions {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
  padding: 16rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  background: inherit;
  box-shadow: 0 -10rpx 24rpx rgba(0, 0, 0, 0.18);
}

.sheet-btn {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  max-width: 100%;
  margin: 0 !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 28rpx !important;
  letter-spacing: 1rpx !important;
  box-sizing: border-box;
  padding: 0 12rpx !important;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.sheet-actions .btn-primary,
.sheet-actions .btn-ghost {
  width: 0;
}

/* 弹层内次级按钮：深色主题提高对比度，避免“取消”看不清 */
.sheet-actions .btn-ghost {
  background: rgba(255, 255, 255, 0.08) !important;
  color: #f3f7ff !important;
  border: 1rpx solid rgba(255, 255, 255, 0.22) !important;
  box-shadow: none !important;
}

.sheet-actions .btn-ghost:active {
  background: rgba(255, 255, 255, 0.14) !important;
  border-color: rgba(147, 197, 253, 0.55) !important;
  color: #ffffff !important;
}

.theme-light.sheet .sheet-actions .btn-ghost,
.sheet.theme-light .sheet-actions .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04) !important;
}

.theme-light.sheet .sheet-actions .btn-ghost:active,
.sheet.theme-light .sheet-actions .btn-ghost:active {
  background: #eff6ff !important;
  border-color: #bfdbfe !important;
  color: #2563eb !important;
  box-shadow: none !important;
}


.sheet-btn::after {
  border: none;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.chip {
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.04);
}

.chip.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.45);
  background: rgba(92, 225, 255, 0.1);
}

/* light */
.theme-light .delta-pill,
.theme-light .bmi-pill {
  background: #f8fafc;
  border-color: #e2e8f0;
}

.theme-light .prog-track {
  background: #e2e8f0;
}

.theme-light .prog-fill {
  background: linear-gradient(90deg, #3b82f6, #60a5fa);
  box-shadow: none;
}

.theme-light .range-tab {
  background: #f1f5f9;
  border-color: transparent;
  color: #64748b;
}

.theme-light .range-tab.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.theme-light .stat-item,
.theme-light .health-box,
.theme-light .level-hint {
  background: #f8fafc;
  border: none;
}

.theme-light .rec-item {
  border-bottom-color: #eef2f7;
}

.theme-light.sheet-mask {
  background: rgba(15, 23, 42, 0.28);
}

.theme-light.sheet,
.sheet.theme-light {
  background: #ffffff;
  color: #0f172a;
  border-color: #e2e8f0;
  box-shadow: 0 -12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.theme-light.sheet .sheet-title,
.sheet.theme-light .sheet-title {
  color: #0f172a;
}

.theme-light.sheet .sheet-label,
.sheet.theme-light .sheet-label {
  color: #64748b;
}

.theme-light.sheet .sheet-handle,
.sheet.theme-light .sheet-handle {
  background: #e2e8f0;
}

.theme-light.sheet .input,
.sheet.theme-light .input {
  background: #f1f5f9;
  color: #0f172a;
  border: 1rpx solid transparent;
  box-shadow: none;
}

.theme-light.sheet .chip,
.sheet.theme-light .chip {
  background: #f1f5f9;
  border-color: transparent;
  color: #64748b;
}

.theme-light.sheet .chip.on,
.sheet.theme-light .chip.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

/* 兼容旧选择器，防止遗漏 */
.theme-light .chip {
  background: #f1f5f9;
  border-color: transparent;
  color: #64748b;
}

.theme-light .chip.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.theme-light .tone-up { color: #e11d48; }
.theme-light .tone-down { color: #16a34a; }
/* Diet summary */
.diet-nums {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  margin: 14rpx 0 12rpx;
}
.diet-n {
  font-size: 48rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}
.diet-u {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}
.diet-remain {
  font-size: 22rpx;
  font-weight: 700;
  padding-bottom: 4rpx;
}
.tone-ok { color: #4ade80; }
.tone-over { color: #f87171; }
.diet-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}
.diet-macro {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-variant-numeric: tabular-nums;
}
.diet-count {
  font-size: 22rpx;
  color: var(--accent);
  flex-shrink: 0;
}
.theme-light .tone-ok { color: #16a34a; }
.theme-light .tone-over { color: #e11d48; }

/* light: hero record entry */
.theme-light .hero-cta {
  background: linear-gradient(135deg, #eff6ff, #f8fafc);
  border-color: #dbeafe;
}

.theme-light .hero-cta-hover {
  background: linear-gradient(135deg, #dbeafe, #f1f5f9);
}

.theme-light .hero-cta-icon {
  color: #2563eb;
  background: #eff6ff;
  border-color: #bfdbfe;
}

.theme-light .hero-cta-title { color: #0f172a; }
.theme-light .hero-cta-sub { color: #64748b; }
.theme-light .hero-cta-arrow { color: #93c5fd; }

.theme-light .empty-cta {
  color: #2563eb;
  background: #eff6ff;
  border-color: #bfdbfe;
}