.weight-records .head-card {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.head-title {
  font-size: 36rpx;
  font-weight: 800;
}

.head-sub {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.rec-card {
  padding-bottom: 18rpx;
}

.rec-main {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.rec-left {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.rec-date {
  font-size: 28rpx;
  font-weight: 600;
}

.rec-note {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.rec-note.muted {
  color: var(--text-muted);
}

.rec-right {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.rec-w {
  font-size: 40rpx;
  font-weight: 800;
  font-variant-numeric: tabular-nums;
}

.rec-u {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.rec-bf {
  margin-left: 10rpx;
  font-size: 22rpx;
  color: var(--accent);
}

.rec-actions {
  display: flex;
  justify-content: flex-end;
  gap: 24rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.act {
  font-size: 24rpx;
  color: var(--accent);
  font-weight: 600;
  padding: 6rpx 4rpx;
}

.act.danger {
  color: #f87171;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
}

.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #121a2c, #0a101c);
  border-radius: 28rpx 28rpx 0 0;
  padding: 16rpx 28rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-bottom: none;
  transform: translateY(110%);
  transition: transform 0.28s ease, bottom 0.18s ease, max-height 0.18s ease;
  max-height: 85vh;
  overflow: hidden;
  box-sizing: border-box;
}

.sheet.on { transform: translateY(0); }

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  margin: 4rpx auto 18rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.sheet-field { margin-bottom: 18rpx; }
.sheet-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.sheet-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding-bottom: 8rpx;
}

.sheet-field-last {
  margin-bottom: 8rpx;
}

.sheet-actions {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
  padding: 16rpx 0 calc(20rpx + env(safe-area-inset-bottom));
  background: inherit;
  box-shadow: 0 -10rpx 24rpx rgba(0, 0, 0, 0.18);
}

.sheet-btn {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  max-width: 100%;
  margin: 0 !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 28rpx !important;
  letter-spacing: 1rpx !important;
  box-sizing: border-box;
  padding: 0 12rpx !important;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.sheet-actions .btn-primary,
.sheet-actions .btn-ghost {
  width: 0;
}

/* 弹层内次级按钮：深色主题提高对比度，避免“取消”看不清 */
.sheet-actions .btn-ghost {
  background: rgba(255, 255, 255, 0.08) !important;
  color: #f3f7ff !important;
  border: 1rpx solid rgba(255, 255, 255, 0.22) !important;
  box-shadow: none !important;
}

.sheet-actions .btn-ghost:active {
  background: rgba(255, 255, 255, 0.14) !important;
  border-color: rgba(147, 197, 253, 0.55) !important;
  color: #ffffff !important;
}

.theme-light.sheet .sheet-actions .btn-ghost,
.sheet.theme-light .sheet-actions .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.04) !important;
}

.theme-light.sheet .sheet-actions .btn-ghost:active,
.sheet.theme-light .sheet-actions .btn-ghost:active {
  background: #eff6ff !important;
  border-color: #bfdbfe !important;
  color: #2563eb !important;
  box-shadow: none !important;
}


.sheet-btn::after {
  border: none;
}

.theme-light .rec-actions {
  border-top-color: #eef2f7;
}

.theme-light .act.danger { color: #e11d48; }

.theme-light.sheet-mask {
  background: rgba(15, 23, 42, 0.28);
}

.theme-light.sheet,
.sheet.theme-light {
  background: #ffffff;
  color: #0f172a;
  border-color: #e2e8f0;
  box-shadow: 0 -12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.theme-light.sheet .sheet-title,
.sheet.theme-light .sheet-title {
  color: #0f172a;
}

.theme-light.sheet .sheet-label,
.sheet.theme-light .sheet-label {
  color: #64748b;
}

.theme-light.sheet .sheet-handle,
.sheet.theme-light .sheet-handle {
  background: #e2e8f0;
}

.theme-light.sheet .input,
.sheet.theme-light .input {
  background: #f1f5f9;
  color: #0f172a;
  border: 1rpx solid transparent;
  box-shadow: none;
}