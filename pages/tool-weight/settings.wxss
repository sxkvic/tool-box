.page-locked {
  overflow: hidden;
  height: 100vh;
  touch-action: none;
}

.weight-settings .field-label {
  margin: 18rpx 0 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.weight-settings .input,
.weight-settings .picker-value {
  margin-bottom: 4rpx;
}

.weight-settings .card-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.weight-settings .text-action {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 4rpx;
}

.weight-settings .text-action:active {
  opacity: 0.7;
}

.field-row {
  display: flex;
  gap: 16rpx;
}

.field-col {
  flex: 1;
  min-width: 0;
}

.seg {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.seg-item {
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.seg-item.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.45);
  background: rgba(92, 225, 255, 0.1);
}

.meta-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin: 16rpx 0 4rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.foot-note {
  margin: 8rpx 8rpx 12rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.bottom-space {
  height: calc(140rpx + env(safe-area-inset-bottom));
}

.seg-3 {
  grid-template-columns: repeat(3, 1fr);
}

.act-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 8rpx;
}

.act-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.act-item.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.45);
  background: rgba(92, 225, 255, 0.1);
}

.act-name {
  font-size: 26rpx;
  font-weight: 700;
}

.act-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.act-item.on .act-desc {
  color: var(--accent);
  opacity: 0.85;
}

/* 底部统一保存 */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  padding: 16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(8, 12, 20, 0), rgba(8, 12, 20, 0.92) 28%, rgba(8, 12, 20, 0.98));
  box-sizing: border-box;
}

.save-bar .save-btn {
  margin-top: 0 !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
}

.save-bar .save-btn::after {
  border: none;
}

.theme-light .seg-item {
  background: #f1f5f9;
  border-color: transparent;
  color: #64748b;
}

.theme-light .seg-item.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.theme-light .act-item {
  background: #f1f5f9;
  border-color: transparent;
}

.theme-light .act-item.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.theme-light .act-item.on .act-desc {
  color: #2563eb;
}

.theme-light .text-action {
  color: #64748b;
}

.theme-light .text-action:active {
  color: #e11d48;
}

.theme-light.save-bar,
.save-bar.theme-light {
  background: linear-gradient(180deg, rgba(245, 247, 251, 0), rgba(245, 247, 251, 0.92) 28%, rgba(245, 247, 251, 0.98));
}


/* 自定义日期弹层 */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.58);
  z-index: 999;
}

.date-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background:
    radial-gradient(120% 80% at 50% -10%, rgba(92, 225, 255, 0.12), transparent 55%),
    linear-gradient(180deg, #141c30 0%, #0b1220 58%, #080d18 100%);
  border-radius: 32rpx 32rpx 0 0;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-bottom: none;
  padding: 12rpx 28rpx calc(18rpx + env(safe-area-inset-bottom));
  transform: translateY(110%);
  transition: transform 0.28s ease;
  box-sizing: border-box;
  box-shadow: 0 -18rpx 48rpx rgba(0, 0, 0, 0.35);
}

.date-sheet.on {
  transform: translateY(0);
}

.date-handle {
  width: 72rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  margin: 4rpx auto 14rpx;
}

.date-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.date-sheet-title {
  font-size: 32rpx;
  font-weight: 740;
  letter-spacing: 1rpx;
  color: #f4f7ff;
}

.date-close {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #9aa6bf;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.date-close:active {
  opacity: 0.75;
}

.date-preview {
  display: flex;
  align-items: baseline;
  gap: 14rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
  border-radius: 18rpx;
  background: rgba(92, 225, 255, 0.08);
  border: 1rpx solid rgba(92, 225, 255, 0.18);
}

.date-preview-label {
  font-size: 22rpx;
  color: #8b95ad;
}

.date-preview-value {
  font-size: 34rpx;
  font-weight: 760;
  letter-spacing: 1rpx;
  color: #5ce1ff;
  font-variant-numeric: tabular-nums;
}

.date-picker-wrap {
  position: relative;
  margin: 4rpx 0 8rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.06);
}

.date-picker-view {
  width: 100%;
  height: 380rpx;
}

.date-opt {
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 620;
  color: rgba(244, 247, 255, 0.88);
  font-variant-numeric: tabular-nums;
}

.date-unit-row {
  pointer-events: none;
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  height: 76rpx;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  align-items: center;
  z-index: 2;
}

.date-unit {
  text-align: right;
  padding-right: 18%;
  font-size: 22rpx;
  color: rgba(92, 225, 255, 0.75);
  font-weight: 600;
}

.date-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.date-btn {
  flex: 1 1 0;
  width: 0;
  min-width: 0;
  margin: 0 !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  font-size: 28rpx !important;
}

.date-actions .btn-ghost {
  background: rgba(255, 255, 255, 0.08) !important;
  color: #f3f7ff !important;
  border: 1rpx solid rgba(255, 255, 255, 0.2) !important;
  box-shadow: none !important;
}

.date-actions .btn-ghost:active {
  background: rgba(255, 255, 255, 0.14) !important;
}

.date-actions .btn-primary,
.date-actions .btn-ghost {
  width: 0;
}

.date-btn::after {
  border: none;
}

/* light */
.theme-light.sheet-mask {
  background: rgba(15, 23, 42, 0.28);
}

.theme-light.date-sheet,
.date-sheet.theme-light {
  background:
    radial-gradient(120% 80% at 50% -10%, rgba(37, 99, 235, 0.1), transparent 55%),
    linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  border-color: #e2e8f0;
  box-shadow: 0 -16rpx 40rpx rgba(15, 23, 42, 0.1);
  color: #0f172a;
}

.theme-light.date-sheet .date-handle,
.date-sheet.theme-light .date-handle {
  background: #e2e8f0;
}

.theme-light.date-sheet .date-sheet-title,
.date-sheet.theme-light .date-sheet-title {
  color: #0f172a;
}

.theme-light.date-sheet .date-close,
.date-sheet.theme-light .date-close {
  color: #64748b;
  background: #f1f5f9;
  border-color: transparent;
}

.theme-light.date-sheet .date-preview,
.date-sheet.theme-light .date-preview {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.theme-light.date-sheet .date-preview-label,
.date-sheet.theme-light .date-preview-label {
  color: #64748b;
}

.theme-light.date-sheet .date-preview-value,
.date-sheet.theme-light .date-preview-value {
  color: #2563eb;
}

.theme-light.date-sheet .date-picker-wrap,
.date-sheet.theme-light .date-picker-wrap {
  background: #f8fafc;
  border-color: #eef2f7;
}

.theme-light.date-sheet .date-opt,
.date-sheet.theme-light .date-opt {
  color: #0f172a;
}

.theme-light.date-sheet .date-unit,
.date-sheet.theme-light .date-unit {
  color: #60a5fa;
}

.theme-light.date-sheet .date-actions .btn-ghost,
.date-sheet.theme-light .date-actions .btn-ghost {
  background: #ffffff !important;
  color: #334155 !important;
  border: 1rpx solid #e2e8f0 !important;
}
