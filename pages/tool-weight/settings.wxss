.weight-settings .field-label {
  margin: 18rpx 0 10rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.weight-settings .input,
.weight-settings .picker-value {
  margin-bottom: 4rpx;
}

.seg {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.seg-item {
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.seg-item.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.45);
  background: rgba(92, 225, 255, 0.1);
}

.meta-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin: 16rpx 0 4rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.foot-note {
  margin: 8rpx 8rpx 40rpx;
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

.theme-light .seg-item {
  background: #f1f5f9;
  border-color: transparent;
  color: #64748b;
}

.theme-light .seg-item.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}
.seg-3 {
  grid-template-columns: repeat(3, 1fr);
}

.act-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.act-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.act-item.on {
  color: var(--accent);
  border-color: rgba(92, 225, 255, 0.45);
  background: rgba(92, 225, 255, 0.1);
}

.act-name {
  font-size: 26rpx;
  font-weight: 700;
}

.act-desc {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.act-item.on .act-desc {
  color: var(--accent);
  opacity: 0.85;
}

.theme-light .act-item {
  background: #f1f5f9;
  border-color: transparent;
}

.theme-light .act-item.on {
  background: #eff6ff;
  color: #2563eb;
  border-color: #bfdbfe;
}

.theme-light .act-item.on .act-desc {
  color: #2563eb;
}
